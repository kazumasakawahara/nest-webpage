---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import IframePlaceholder from '../components/IframePlaceholder.astro';
import { site } from '../lib/site';
---

<BaseLayout
  title="アクセス"
  description="NPO法人nest事務局へのアクセス。福岡県北九州市小倉北区木町3丁目6−7。"
  transparentHeader={true}
>
  <Hero
    eyebrow="Access"
    title="事務局までのご案内"
    lead="北九州市小倉北区木町。最寄りはJR南小倉駅、徒歩圏内です。"
    size="md"
    image="/images/nest-image1/kimachiya-gaikan.png"
    placeholderLabel="ACCESS — 街並み"
  />

  <section class="section">
    <div class="container">
      <div class="access-grid">

        <div class="access-info reveal">
          <span class="eyebrow">Office</span>
          <h2 class="access-info__title">事務局情報</h2>

          <dl class="access-dl">
            <dt>法人名</dt>
            <dd>{site.name}</dd>

            <dt>所在地</dt>
            <dd>
              〒803-0851<br />
              福岡県北九州市小倉北区<br />
              木町3丁目6−7
            </dd>

            <dt>TEL / FAX</dt>
            <dd>
              <a href={`tel:${site.tel.replaceAll('-', '')}`} class="access-tel">{site.tel}</a>
            </dd>

            <dt>電話受付</dt>
            <dd>{site.telHours}</dd>
          </dl>
        </div>

        <div class="access-map reveal" data-delay="1">
          <span class="eyebrow">Map</span>
          <h2 class="access-map__title">地図</h2>
          <IframePlaceholder
            icon="📍"
            title="Googleマップ"
            note='Google Maps で「福岡県北九州市小倉北区木町3丁目6−7」を検索 → 「共有」→「地図を埋め込む」→ HTMLをコピー → このdivと置き換え。'
            minHeight="440px"
          />
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .access-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: var(--space-7);
    align-items: start;
  }

  .access-info,
  .access-map {
    background-color: var(--color-paper);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
    box-shadow: var(--shadow-soft);
  }

  .access-info__title,
  .access-map__title {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--color-green-900);
    margin-bottom: var(--space-5);
  }

  .access-dl {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-4);
  }

  .access-dl dt {
    font-size: 12px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-terra-500);
    font-weight: 600;
    padding-top: 4px;
  }

  .access-dl dd {
    color: var(--color-ink);
    line-height: 1.85;
  }

  .access-tel {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 600;
    color: var(--color-green-900);
  }

  @media (max-width: 980px) {
    .access-grid { grid-template-columns: 1fr; }
  }
</style>
