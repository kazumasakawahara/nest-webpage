---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatsSection from '../components/StatsSection.astro';
import VoiceSection from '../components/VoiceSection.astro';
import ServiceCardGrid from '../components/ServiceCardGrid.astro';
import NewsList from '../components/NewsList.astro';
import CtaBlock from '../components/CtaBlock.astro';
import { site } from '../lib/site';

const services = [
  {
    title: 'キッチン＆マルシェ 木町家',
    body: '南小倉駅前の就労継続支援B型事業所。米粉パン・スイーツ・四季のお料理をご提供しています。',
    href: '/kimachiya/',
    icon: '🍞',
    image: '/images/nest-image1/kimachiya-bread-salad.png',
    imageAlt: '木町家の米粉パンとサラダ',
  },
  {
    title: 'nestDesign',
    body: '創造性をテーマにした就労継続支援B型。オリジナルグッズ・アート・印刷物制作に取り組んでいます。',
    href: '/nest-design/',
    icon: '🎨',
    image: '/images/nest-image2/nestdesign_working.png',
    imageAlt: 'nestDesign の制作風景',
  },
  {
    title: '共同生活援助（グループホーム）',
    body: '原町・木町・弁天町などの14拠点で運営。地域で安心して暮らせる住まいの場をつくっています。',
    href: '/group-home/',
    icon: '🏠',
    image: '/images/nest-image2/neststation_gaikan.png',
    imageAlt: 'nest STATION の外観',
  },
  {
    title: '当事者活動支援',
    body: '鉄道俱楽部や当事者研究など、本人が主体的に取り組む活動を伴走しています。',
    href: '/peer-activities/',
    icon: '🚃',
    image: '/images/peer-activities-card.jpg',
    imageAlt: '鉄道博物館での当事者活動の様子',
  },
  {
    title: '地域生活支援の取り組み',
    body: '日本財団助成「生と性の視点から見た巣立ちを考える地域生活支援」。今年度まで実施中です。',
    href: '/sudachi/',
    icon: '🌱',
    badge: '実施中',
    image: '/images/nest-image1/mori_subako3.png',
    imageAlt: '森の中の巣箱',
  },
  {
    title: '入会・ご支援のお願い',
    body: '正会員・賛助会員、ボランティアの方を募集しています。nestの活動を支えてください。',
    href: '/join/',
    icon: '💌',
    image: '/images/join-card.jpg',
    imageAlt: '川辺を泳ぐ親子の鴨',
  },
];

const promises = [
  {
    num: '01',
    title: '本人のペースを尊重する',
    body: '急かさない。できることから、少しずつ。一人ひとりの「やってみたい」を、いちばん大切にします。',
  },
  {
    num: '02',
    title: '家族とともに歩む',
    body: 'ご本人だけでなく、ご家族の不安にも寄り添います。いつでも気軽に相談できる関係を、長く。',
  },
  {
    num: '03',
    title: '巣立った後も、つながり続ける',
    body: '「巣立ち」はゴールではなく、はじまり。地域全体で支え合う仕組みを、ゆっくり育てています。',
  },
];

const milestones = [
  {
    year: '2006',
    title: '特定非営利活動法人nest 設立',
    body: '発達障がいのある人とご家族の暮らしを支えるため、北九州市小倉北区に設立しました。',
  },
  {
    year: 'これまで',
    title: '地域とともに、少しずつ',
    body: '就労継続支援B型「木町家」「nestDesign」、共同生活援助、当事者活動へと、活動の輪を広げてきました。',
  },
  {
    year: 'いま',
    title: '14拠点のグループホームと、1つのB型事業所',
    body: '設立から約20年。地域生活支援の取り組みも続けながら、巣立ちと安らぎの場所であり続けます。',
  },
];
---

<BaseLayout
  title="TOP"
  description={site.description}
>
  <Hero
    eyebrow="NPO法人 nest — since 2006"
    title="巣立っても、"
    titleSub="いつでも帰ってこられる。"
    lead="飛び立っても羽を休める場所。知的や精神に障がいのある人とご家族の暮らしを、地域とともに支えています。"
    size="lg"
    image="/images/nest-image1/mori_subako2.jpg"
    imagePosition="74% center"
    placeholderLabel="MAIN VISUAL — 厨房 / グループホーム / アート"
  >
    <div class="hero-actions">
      <a href="/about/" class="btn btn--accent btn--lg">
        nestについて知る
        <span class="btn__icon" aria-hidden="true">→</span>
      </a>
      <a href="/contact/" class="btn btn--ghost btn--lg">見学を申し込む</a>
    </div>
  </Hero>

  <!-- ===== Mission ===== -->
  <section class="section" aria-labelledby="mission-title">
    <div class="container container--narrow">
      <div class="mission reveal">
        <span class="eyebrow eyebrow--center">Our Mission</span>
        <h2 class="mission__title" id="mission-title">
          <span class="title-underline">nestは【鳥の巣】。</span><br />
          <span class="mission__title-sub is-hand">巣立ちと、安らぎの場所。</span>
        </h2>
        <div class="mission__body">
          <p>
            特定非営利活動法人nestは、知的や精神に障がいのある人、そしてその家族のそれぞれの生活や人生がより豊かになるよう、
            個々のライフステージに応じた支援と、誰もが住みよい地域社会づくりをめざして事業を展開しています。
          </p>
          <p>
            障がいの有無にかかわらず、事業に参加したみんなが笑顔になれるような、
            そんな楽しい活動をしていきたいと思っています。
          </p>
        </div>
        <a href="/about/" class="mission__link">
          設立の経緯を読む
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 代表ごあいさつ ===== -->
  <section class="section section--paper" aria-labelledby="rep-title">
    <div class="container container--narrow">
      <div class="rep reveal">
        <span class="eyebrow eyebrow--center">Message</span>
        <h2 class="section__title section__title--center" id="rep-title">代表ごあいさつ</h2>
        <div class="rep__layout">
          <figure class="rep__portrait">
            <img
              src="/images/rep-hayashi.png"
              alt="特定非営利活動法人nest 代表 林 澄江"
              width="1188"
              height="1324"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="rep__main">
            <div class="rep__body">
              <p>
                知的や精神に障がいのある人も、ない人も。誰もが笑顔で暮らせる地域でありたい——
                その願いから、nestははじまりました。
              </p>
              <p>
                設立以来、私たちは「親なき後」という切実な問いに向き合ってきました。
                木町STATIONやグループホーム、KAREIプロジェクトなど、多くのご家族と手を取り合いながら、
                本人がその人らしく地域で暮らすための仕組みを、一つひとつ形にしてきました。
              </p>
              <p>
                大切にしてきたのは、「誰かに任せる」のではなく「自分たちで仕組みを作る」という姿勢です。
                巣立ちネットでは、親同士が不安を分かち合い、専門家や地域とも連携しながら、互いに支え合う輪を広げています。
                一人で抱えれば重く感じられる不安も、同じ思いを持つ仲間と語り合えば、希望のある計画へと変わっていきます。
              </p>
              <p>
                子どもたちの「巣立ち」と、その先の安心な未来を——どうぞ、私たちと一緒にデザインしていきましょう。
              </p>
            </div>
            <p class="rep__sign">
              <span class="rep__role">特定非営利活動法人nest 代表</span>
              <span class="rep__name is-hand">{site.representative}</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Stats ===== -->
  <StatsSection />

  <!-- ===== 3つの約束 / 安心の理由 ===== -->
  <section class="section" aria-labelledby="promise-title">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <span class="eyebrow eyebrow--center">Our Promise</span>
        <h2 class="section__title section__title--center" id="promise-title">
          nestがお約束する、3つのこと
        </h2>
        <p class="section__lead section__lead--center">
          巣立ちは、ゴールではなく、はじまり。<br />
          安心して任せていただくために、私たちが大切にしていることです。
        </p>
      </div>

      <div class="grid-3">
        {
          promises.map((p, i) => (
            <article class="card promise reveal" data-delay={i + 1}>
              <span class="promise__num is-hand">{p.num}</span>
              <h3 class="card__title">{p.title}</h3>
              <p class="card__text">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Services ===== -->
  <section class="section section--cream" aria-labelledby="services-title">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Our Work</span>
        <div class="section-head__row">
          <h2 class="section__title" id="services-title">現在の主な事業</h2>
          <p class="section-head__lead">
            nestが取り組んでいる6つの事業。<br />
            「働く・暮らす・つながる」を、それぞれの場所で支えています。
          </p>
        </div>
      </div>

      <ServiceCardGrid cards={services} columns={3} />
    </div>
  </section>

  <!-- ===== これまでの歩み ===== -->
  <section class="section section--sand" aria-labelledby="history-title">
    <div class="container container--narrow">
      <div class="section-head section-head--center reveal">
        <span class="eyebrow eyebrow--center">Our Story</span>
        <h2 class="section__title section__title--center" id="history-title">これまでの歩み</h2>
      </div>

      <ol class="timeline">
        {
          milestones.map((m, i) => (
            <li class="timeline__item reveal" data-delay={i + 1}>
              <span class="timeline__year is-hand">{m.year}</span>
              <div class="timeline__body">
                <h3 class="timeline__title">{m.title}</h3>
                <p class="timeline__text">{m.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ===== Voice ===== -->
  <VoiceSection />

  <!-- ===== News ===== -->
  <section class="section section--sand" aria-labelledby="news-title">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">News</span>
        <div class="section-head__row">
          <h2 class="section__title" id="news-title">nest News</h2>
          <a href="/news/" class="section-head__link">
            一覧を見る
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <NewsList limit={4} />
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section">
    <div class="container">
      <CtaBlock
        title="まずは見学から、お気軽に。"
        body="利用のご相談・見学・体験は、随時受け付けています。電話 or フォームでお気軽にどうぞ。"
        primary={{ label: 'お問い合わせフォーム', href: '/contact/' }}
        secondary={{ label: 'アクセス・地図を見る', href: '/access/' }}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .mission {
    text-align: center;
  }

  .mission__title {
    font-family: var(--font-hand);
    font-size: 36px;
    font-weight: 600;
    color: var(--color-green-900);
    line-height: 1.5;
    margin-bottom: var(--space-6);
  }

  .mission__title-sub {
    font-size: 0.78em;
    color: var(--color-terra-500);
  }

  .mission__body {
    text-align: left;
    color: var(--color-ink);
    font-size: 16px;
    line-height: 2;
  }

  .mission__body p + p { margin-top: var(--space-4); }

  .mission__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    font-weight: 600;
    color: var(--color-green-700);
    padding-bottom: 4px;
    border-bottom: 1.5px solid var(--color-green-700);
  }

  .mission__link:hover {
    color: var(--color-terra-500);
    border-color: var(--color-terra-500);
  }

  /* ===== 代表ごあいさつ ===== */
  .rep {
    text-align: center;
  }

  .rep__layout {
    display: grid;
    grid-template-columns: 230px 1fr;
    gap: var(--space-7);
    align-items: start;
    margin-top: var(--space-6);
  }

  /* やわらかい手づくり風のポートレート枠 */
  .rep__portrait {
    position: relative;
    margin: 0;
  }

  .rep__portrait::before {
    content: '';
    position: absolute;
    inset: -10px -12px -14px -10px;
    background: var(--color-green-100);
    border-radius: var(--radius-blob);
    z-index: 0;
  }

  .rep__portrait img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    background-color: var(--color-paper);
    box-shadow: var(--shadow-card);
  }

  .rep__main {
    min-width: 0;
  }

  .rep__body {
    text-align: left;
    color: var(--color-ink);
    font-size: 16px;
    line-height: 2;
  }

  .rep__body p + p { margin-top: var(--space-4); }

  .rep__sign {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    margin-top: var(--space-6);
  }

  .rep__role {
    font-size: 13px;
    color: var(--color-ink-mute);
    letter-spacing: 0.05em;
  }

  .rep__name {
    font-size: 28px;
    color: var(--color-green-900);
    letter-spacing: 0.08em;
  }

  /* ===== 3つの約束 ===== */
  .promise {
    position: relative;
    gap: var(--space-3);
  }

  .promise__num {
    font-size: 32px;
    line-height: 1;
    color: var(--color-terra-500);
  }

  /* ===== これまでの歩み（Timeline） ===== */
  .timeline {
    position: relative;
    margin-top: var(--space-2);
    padding-left: var(--space-6);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--color-terra-100),
      var(--color-terra-500) 30%,
      var(--color-green-500) 90%
    );
  }

  .timeline__item {
    position: relative;
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: var(--space-5);
    align-items: baseline;
  }

  .timeline__item:not(:last-child) {
    margin-bottom: var(--space-7);
  }

  .timeline__item::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-6) + 1px);
    top: 10px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-paper);
    border: 3px solid var(--color-terra-500);
  }

  .timeline__year {
    font-size: 22px;
    color: var(--color-terra-700);
    letter-spacing: 0.04em;
  }

  .timeline__title {
    font-family: var(--font-hand);
    font-size: 19px;
    font-weight: 600;
    color: var(--color-green-900);
    line-height: 1.5;
    margin-bottom: var(--space-2);
  }

  .timeline__text {
    color: var(--color-ink-mute);
    font-size: 15px;
    line-height: 1.85;
  }

  /* ===== Shared section heads ===== */
  .section-head { margin-bottom: var(--space-7); }

  .section-head--center {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
  }

  .section-head__row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .section-head__lead {
    color: var(--color-ink-mute);
    font-size: 15px;
    line-height: 1.85;
    max-width: 400px;
  }

  .section-head__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-green-700);
    white-space: nowrap;
  }

  .section-head__link:hover { color: var(--color-terra-500); }

  @media (max-width: 768px) {
    .mission__title { font-size: 26px; }
    .section-head__row { flex-direction: column; align-items: flex-start; }

    .rep__layout {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: var(--space-6);
    }
    .rep__portrait {
      width: 200px;
      max-width: 70%;
    }
    .rep__main { text-align: left; }
    .rep__sign { align-items: center; }

    .timeline { padding-left: var(--space-5); }
    .timeline__item {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
