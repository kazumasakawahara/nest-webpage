---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';
import PdfDocCard from '../components/PdfDocCard.astro';
import PdfPreview from '../components/PdfPreview.astro';

const steps = [
  {
    name: 'STATION / BRANCH',
    body: '世話人によるサポートを受けつつ、少しずつ自分のペースで暮らします。',
  },
  {
    name: 'SATELLITE',
    body: 'より一人暮らしに近い住まいです。自立した生活を見据えて、その人らしく過ごします。',
  },
];

// グループホーム紹介ガイド（B6リーフレット）。開いて読む／ダウンロードできる。
const guide = {
  title: 'グループホームガイド（共同生活援助）',
  file: '/pdfs/group-home/nest-grouphome-guide-2026.pdf',
  meta: '2026年版 ・ PDF ・ 約1MB',
  note: '見学・体験のご相談はお気軽にどうぞ。',
};
---

<BaseLayout
  title="グループホーム"
  description="NPO法人nestのグループホームは、町内に点在する賃貸住宅の居室で、利用者が地域の一員として暮らすことを支えています。"
>
  <div class="gh-hero">
    <Hero
      eyebrow="Group Home"
      title="グループホーム"
      lead="地域で暮らす、を支える住まい"
      size="md"
      image="/images/grouphome-interior.png"
      imagePosition="center 32%"
      placeholderLabel="GROUP HOME"
    />
  </div>

  <!-- ===== 理念（主役） ===== -->
  <section class="section">
    <div class="container container--narrow reveal">
      <span class="eyebrow">Our Approach</span>
      <h2 class="section__title">施設ではなく、地域の暮らしの中で</h2>
      <p style="font-size:16px; line-height:2; color:var(--color-ink); margin-bottom:var(--space-5);">
        nest のグループホームは、ひとつの施設に利用者を集めて運営するものではありません。
        わたしたちは、町内に点在する賃貸マンションの居室や住宅を法人で借り上げ、
        そのひと部屋ひと部屋を利用者の住まいとしています。
      </p>
      <p style="font-size:16px; line-height:2; color:var(--color-ink); margin-bottom:var(--space-5);">
        だからこそ、利用者は特別な場所に隔離されることなく、ご近所との何気ない挨拶や、
        近くのお店での買い物といった、当たり前の地域の暮らしの中で日々を送ることができます。
        「本人が地域で暮らす」——それが、わたしたち nest の願いです。
      </p>
      <p style="font-size:16px; line-height:2; color:var(--color-ink);">
        また、利用者の中には強いこだわりを持つ方も少なくありません。
        大人数での集団生活がむずかしい方も、分散した住まいであれば、
        一人ひとりの個性とペースを尊重しながら、その人らしい暮らしを支えることができます。
      </p>
    </div>
  </section>

  <!-- ===== 住まいの段階（概念） ===== -->
  <section class="section section--sand">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:var(--space-7);">
        <span class="eyebrow eyebrow--center">Two Steps</span>
        <h2 class="section__title section__title--center">自立度に応じた住まい方</h2>
      </div>

      <div class="grid-2">
        {
          steps.map((s, i) => (
            <article class="card reveal" data-delay={(i % 3) + 1}>
              <h3 class="card__title">{s.name}</h3>
              <p class="card__text">{s.body}</p>
            </article>
          ))
        }
      </div>

      <p class="reveal" style="text-align:center; margin-top:var(--space-6); font-size:14px; color:var(--color-ink-mute);">
        現在、町内に <strong style="color:var(--color-green-900);">14の住まい</strong> を運営しています。
      </p>
    </div>
  </section>

  <!-- ===== 紹介ガイド（PDF資料） ===== -->
  <section class="section">
    <div class="container container--narrow reveal">
      <span class="eyebrow">Guide</span>
      <h2 class="section__title">グループホームガイド</h2>
      <p style="font-size:16px; line-height:2; color:var(--color-ink); margin-bottom:var(--space-5);">
        nest のグループホームについて、運営の考え方から日々の支援、暮らしのリズム、入居までの流れまでをまとめた紹介ガイドです。
        下のカードから、その場で開いて読む・ダウンロードしていただけます。
      </p>
      <ul class="gh-guide-points">
        <li><strong>運営のコンセプト</strong> — 利用者を一つの施設に集めず、nest木町STATION をハブに、徒歩圏内に点在する住まいで「自分なりの暮らし方」を支えます。仲間と食事を共にすることを大切にしています。</li>
        <li><strong>支援の概要</strong> — 金銭・服薬の管理、地域医療機関との連携や訪問看護、通院・行政手続きの同行、日中／夜間の支援、自立・意思決定支援。</li>
        <li><strong>グループホームでの暮らし</strong> — 規則正しい1日のリズム（起床〜通所〜帰舎〜夕食・入浴）と、「みんなの会（自治会活動）」「できることふやし隊」などの年間の取り組み。</li>
        <li><strong>入居までの流れ</strong> — 相談 → 見学 → 面談 → 内容説明 → 体験入居 → 市町村への申請 → 利用契約 → 入居開始。</li>
      </ul>
      <div style="margin-top:var(--space-6);">
        <PdfDocCard {...guide} />
      </div>
    </div>
  </section>

  <PdfPreview />

  <!-- ===== 問い合わせ動線 ===== -->
  <section class="section">
    <div class="container">
      <CtaBlock
        title="見学・ご相談について"
        body="ご利用の検討・見学は個別にご対応します。お気軽にお問い合わせください。"
        primary={{ label: 'お問い合わせフォーム', href: '/contact/' }}
        secondary={{ label: 'nestについて', href: '/about/' }}
        variant="dark"
      />
    </div>
  </section>
</BaseLayout>

<!-- グループホームのHeroだけ、可読性オーバーレイを弱めて水彩のあたたかさを前に出す。
     共有Heroコンポーネントには手を入れず、このページのラッパー配下のみに限定して上書きする。 -->
<style is:global>
  .gh-hero .hero__bg {
    filter: brightness(1.06) saturate(1.06);
  }

  .gh-hero .hero__overlay {
    background:
      linear-gradient(100deg,
        rgba(16, 34, 17, 0.70) 0%,
        rgba(16, 34, 17, 0.52) 30%,
        rgba(16, 34, 17, 0.28) 52%,
        rgba(16, 34, 17, 0.10) 70%,
        rgba(16, 34, 17, 0) 85%);
  }

  .gh-hero .hero__overlay::after {
    background: linear-gradient(to top, rgba(16, 34, 17, 0.34), rgba(16, 34, 17, 0) 42%);
  }

  @media (max-width: 768px) {
    .gh-hero .hero__overlay {
      background: linear-gradient(
        180deg,
        rgba(16, 34, 17, 0.42) 0%,
        rgba(16, 34, 17, 0.26) 38%,
        rgba(16, 34, 17, 0.48) 100%
      );
    }
    .gh-hero .hero__overlay::after { background: none; }
  }
</style>

<style>
  .gh-guide-points {
    list-style: none;
    display: grid;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
  }

  .gh-guide-points li {
    position: relative;
    padding-left: 1.4em;
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-ink);
  }

  .gh-guide-points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-terra-500);
  }

  .gh-guide-points strong { color: var(--color-green-900); }
</style>
