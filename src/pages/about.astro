---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PdfPreview from '../components/PdfPreview.astro';
import { site } from '../lib/site';

// ニュースレター「巣箱」バックナンバー（新しい号から）。
// 公開ページには最新号のみ掲載し、過去号は会員ページ（/members/newsletter/）限定。
// PDF は public/pdfs/newsletter-archive/subako/ に、表紙画像は public/images/newsletter/ に配置。
// 表紙は横長レイアウト（1241x800）。発行日は各号の表紙記載に基づく。
const newsletters = [
  { vol: 'vol.15', date: '2025年10月発行', file: '/pdfs/newsletter-archive/subako/subako15.pdf', cover: '/images/newsletter/subako-vol15-cover.jpg' },
];
const latest = newsletters[0];

// 最新号（vol.15）の目次。号を更新したら、この内容も差し替える。
const latestIndex = [
  { cat: '巻頭特集', name: 'つくることが「生きる力」になる ネストデザイン', desc: 'ひとりひとりの色が光る作品づくり。支援員の想い、新人メンバー紹介、メンバーへのQ&A、イラスト傘や卵パックの湿気とりまで。' },
  { cat: '木町家', name: '今日も「暖かさ」が漂う キッチン&マルシェ木町家', desc: '手づくりの味、お弁当・オードブル。料理長と支援員が語る、創作現場のいま。' },
  { cat: 'イベント', name: '木町家のにぎわい', desc: '木町家寄席（七代目 柳亭燕路さん）、木町家誕生祭、小さな音楽室。地域とつながる催しの記録。' },
  { cat: 'B型', name: 'B型のあゆみ', desc: '新メンバーを迎える入所式と、災害の擬似体験で学ぶ防災研修＆ランチ。' },
  { cat: 'コグトレ', name: '小さな一歩から、大きな実感へ', desc: '身体を使った認知トレーニング2年目。「楽しい！だから続く」取り組みの様子。' },
  { cat: '現場実習', name: '「はたらくってたのしい！」を体感できる場', desc: '実習生・野口ミホさんの2週間の体験と、見守るご家族の声。' },
  { cat: 'グループホーム', name: '暮らしと健康を支える、もうひとつの我が家', desc: '年間行事、入居者それぞれの日々、鉄道倶楽部の活動、健康管理と支援者の声。' },
  { cat: '活動・編集後記', name: 'ネストがんばれバザール ／ 会員募集 ／「峠を越えて」', desc: '活動を支えるバザールのご案内、会員募集、理事長による編集後記。' },
];
---

<BaseLayout
  title="nestについて"
  description="NPO法人nestの設立経緯・理念・事業概要をご紹介します。知的や精神に障がいのある子どもの親たちの思いから生まれたNPO法人です。"
>
  <Hero
    eyebrow="About nest"
    title="想いを、かたちに。"
    lead="障がいのある人やその家族の「暮らす」を支援する。 障がいのある人が地域で安心安全に自分らしい生活を送ることができるように。"
    size="md"
    image="/images/nest-image1/mori_subako4.png"
    placeholderLabel="ABOUT — 法人活動風景"
  />

  <!-- ===== 設立経緯 ===== -->
  <section class="section">
    <div class="container container--narrow">
      <div class="reveal">
        <span class="eyebrow eyebrow--center">Our Origin</span>
        <h2 class="section__title section__title--center">nest 設立の経緯</h2>

        <div class="prose">
          <p>
            NPO法人nestは発達障がいのある子どもの親たちの願いから発足しました。発達障がいは、障がいがあることが外見でわかりにくく、
            当時は社会的認知度もまだまだ高くありませんでした。また従来の障がい福祉サービスの対象から漏れてしまうことも多く、
            『制度の谷間にある障がい』とも言われてきました。
          </p>
          <p>
            このような状況の中で実際に子育てをしてきた親たちが、自分の子育てを通して築いてきたネットワークを活用して、
            同様の困難さを抱えている本人や家族に対する支援の仕組みをつくり、これらを通して本人や家族の自立した地域生活を
            ともに築いていきたいとの思いから、<strong>{site.established}</strong>に設立しました。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 理念 ===== -->
  <section class="section section--cream" aria-labelledby="philosophy-title">
    <div class="container container--narrow">
      <div class="reveal text-center">
        <span class="eyebrow eyebrow--center">Our Philosophy</span>
        <h2 class="section__title section__title--center" id="philosophy-title">nestの理念</h2>
      </div>

      <div class="creed reveal">
        <p class="creed__lead">自分のことは、自分で決める。</p>
        <p class="creed__sub">——どんな障がいがあっても、それは変わらない。</p>
      </div>

      <div class="prose reveal" data-delay="1">
        <p>
          たとえどんな障がいがあろうとも、<strong>その人に関することを決める権利</strong>は、
          ほかの誰でもなく、<strong>その人自身</strong>にあります。
          これは特別なことではなく、だれにとっても当たり前のこと。
          わたしたちは、まずこの当然のことを確認することから始めます。
        </p>
        <p>
          そして nest の使命は、その当然の権利を、その人自身がきちんと行使できるように支えることにあります。
          「本人に代わって決める」のではなく、<strong>「本人が決められるように、となりで支える」</strong>——
          その一点を、すべての活動のまんなかに置いています。
        </p>
        <p>
          同時に、「自分のことは自分で決める」権利は、まわりの人にも等しくあります。
          だからこそ、誰かと関わるときには、相手の気持ちや決める権利を尊重し、
          <strong>きちんと「同意」を得ること</strong>が欠かせません。
          自分の意思を大切にすることと、相手の意思を大切にすること——その両方を本人とともに学び、
          伝えていくことも、わたしたちの支援の大切な役割だと考えています。
        </p>
      </div>
    </div>
  </section>

  <!-- ===== 事業一覧 ===== -->
  <section class="section section--sand" aria-labelledby="services-title">
    <div class="container">
      <div class="section-head reveal text-center">
        <span class="eyebrow eyebrow--center">Our Activities</span>
        <h2 class="section__title section__title--center" id="services-title">主な事業</h2>
      </div>

      <div class="biz-grid">

        <article class="biz reveal">
          <div class="biz__num">01</div>
          <h3 class="biz__title">特定非営利活動に係わる事業</h3>
          <ul class="biz__list">
            <li>地域内での人的交流や支え合いの創出による福祉コミュニティづくり
              <ul>
                <li>木町家映画上映会（木町チャレンジ１）</li>
                <li>町内会花壇整備（木町チャレンジ２）</li>
              </ul>
            </li>
            <li>発達障がい児・者への当事者活動支援事業（鉄道俱楽部、当事者研究）</li>
            <li>発達障がい児・者への余暇活動支援事業（旅友サークル）</li>
            <li>発達障がい児への学習・生活支援事業（教育・生活相談）</li>
          </ul>
        </article>

        <article class="biz reveal" data-delay="1">
          <div class="biz__num">02</div>
          <h3 class="biz__title">障がい福祉サービス事業</h3>
          <ul class="biz__list">
            <li>共同生活援助（グループホーム）
              <ul>
                <li>原町STATION／木町BRANCH／木町BRANCH２／木町BRANCH３／木町三丁目BRANCH</li>
                <li>弁天町STATION／弁天BRANCH／木町SATELLITE</li>
                <li>木町三丁目SATELLITE／木町三丁目SATELLITE２</li>
                <li>弁天町SATELLITE／弁天町SATELLITE２</li>
              </ul>
            </li>
            <li>就労継続支援B型
              <ul>
                <li>キッチン＆マルシェ木町家</li>
                <li>ネストデザイン</li>
              </ul>
            </li>
          </ul>
        </article>

        <article class="biz reveal" data-delay="2">
          <div class="biz__num">03</div>
          <h3 class="biz__title">その他の事業</h3>
          <ul class="biz__list">
            <li>発達障がい者への生活支援事業（生活相談）</li>
            <li>発達障がい児・者への理解啓発のための広報事業（講演会、ニュースレター「巣箱」発行）</li>
            <li>発達障がい児・者の家族への支援事業
              <ul>
                <li>巣立ちプロジェクト</li>
                <li>nestくらしサポートネット運営</li>
                <li>プチ懇親会</li>
              </ul>
            </li>
          </ul>
        </article>

      </div>
    </div>
  </section>

  <!-- ===== ニュースレター ===== -->
  <section class="section" aria-labelledby="newsletter-title">
    <div class="container">
      <div class="section-head reveal text-center">
        <span class="eyebrow eyebrow--center">Newsletter</span>
        <h2 class="section__title section__title--center" id="newsletter-title">
          nestの想いを伝える
        </h2>
        <p class="section__lead section__lead--center">
          ニュースレター「巣箱」<br />
          法人の活動報告や、スタッフ・利用者の声を定期発行でお届けしています。
        </p>
      </div>

      <div class="nl-layout">
        <article class="pdf-card nl-layout__cover reveal">
          <a class="pdf-card__cover js-pdf-view" href={latest.file} target="_blank" rel="noopener"
             data-title={`ニュースレター巣箱 ${latest.vol}`} aria-label={`巣箱 ${latest.vol}（PDF）を開いて読む`}>
            <img src={latest.cover} alt={`巣箱 ${latest.vol} の表紙`} width="1241" height="800" loading="lazy" />
            <span class="pdf-card__hint" aria-hidden="true">クリックで読む</span>
          </a>
          <div class="pdf-card__body">
            <h3 class="pdf-card__vol">巣箱 {latest.vol}</h3>
            {latest.date && <p class="pdf-card__date">{latest.date}</p>}
            <a href={latest.file} class="btn btn--outline" download>PDFダウンロード</a>
          </div>
        </article>

        <div class="nl-index reveal" data-delay="1">
          <div class="nl-index__head">
            <span class="nl-index__badge">{latest.vol}</span>
            <span class="nl-index__title">この号の内容</span>
          </div>
          <ol class="nl-index__list">
            {
              latestIndex.map((item) => (
                <li>
                  <span class="nl-index__cat">{item.cat}</span>
                  <p class="nl-index__name">{item.name}</p>
                  <p class="nl-index__desc">{item.desc}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </section>

  <PdfPreview />
</BaseLayout>

<style>
  .prose p {
    font-size: 16px;
    line-height: 2;
    color: var(--color-ink);
  }

  .prose p + p { margin-top: var(--space-5); }
  .prose strong { color: var(--color-green-900); font-weight: 600; }

  .creed {
    text-align: center;
    margin: var(--space-7) 0;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .creed__lead {
    font-family: var(--font-hand);
    font-size: 34px;
    font-weight: 600;
    color: var(--color-green-900);
    line-height: 1.5;
  }

  .creed__sub {
    margin-top: var(--space-4);
    font-size: 16px;
    color: var(--color-terra-700);
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .creed__lead { font-size: 24px; }
  }

  .biz-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .biz {
    background-color: var(--color-paper);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
    position: relative;
    box-shadow: var(--shadow-soft);
  }

  .biz__num {
    position: absolute;
    top: var(--space-5);
    right: var(--space-6);
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 600;
    color: var(--color-terra-100);
    line-height: 1;
  }

  .biz__title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--color-green-900);
    margin-bottom: var(--space-4);
    padding-right: 80px;
  }

  .biz__list {
    list-style: none;
    color: var(--color-ink);
  }

  .biz__list > li {
    position: relative;
    padding-left: 1.4em;
    margin-bottom: var(--space-3);
    line-height: 1.85;
  }

  .biz__list > li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85em;
    width: 8px;
    height: 1.5px;
    background-color: var(--color-terra-500);
  }

  .biz__list ul {
    list-style: none;
    margin-top: var(--space-2);
    color: var(--color-ink-mute);
    font-size: 14px;
  }

  .biz__list ul li {
    position: relative;
    padding-left: 1em;
    line-height: 1.85;
  }

  .biz__list ul li::before {
    content: '・';
    position: absolute;
    left: 0;
    color: var(--color-green-700);
  }

  /* PDF cards */
  .pdf-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .pdf-card__cover {
    display: block;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
    transition: transform var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out);
  }

  .pdf-card__cover img {
    display: block;
    width: 100%;
    height: auto;
  }

  .pdf-card__cover:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }

  /* 表紙が「クリックで読める」と分かるヒント帯 */
  .pdf-card__hint {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 6px 4px;
    background: rgba(26, 38, 32, 0.74);
    color: #fff;
    font-size: 12px;
    text-align: center;
    letter-spacing: 0.04em;
  }

  .pdf-card__hint::before { content: '🔍 '; }

  .pdf-card__cover:hover .pdf-card__hint { background: var(--color-terra-500); }

  .pdf-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-align: center;
  }

  .pdf-card__vol {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--color-green-900);
  }

  .pdf-card__date {
    font-size: 13px;
    color: var(--color-ink-mute);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  /* ニュースレター：左カード ＋ 右に最新号の目次 */
  .nl-layout {
    display: grid;
    grid-template-columns: minmax(0, 340px) 1fr;
    gap: var(--space-7);
    align-items: start;
  }

  .nl-layout__cover {
    position: sticky;
    top: var(--space-6);
  }

  @media (max-width: 860px) {
    .nl-layout {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .nl-layout__cover {
      position: static;
      max-width: 360px;
      margin: 0 auto;
    }
  }

  .nl-index {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-soft);
  }

  .nl-index__head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-line);
  }

  .nl-index__badge {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 14px;
    color: #fff;
    background: var(--color-green-700);
    padding: 3px 14px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .nl-index__title {
    font-family: var(--font-serif);
    font-size: var(--fs-h3);
    color: var(--color-green-900);
  }

  .nl-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: nl;
    display: grid;
    gap: var(--space-5);
  }

  @media (min-width: 861px) {
    .nl-index__list {
      grid-template-columns: 1fr 1fr;
      column-gap: var(--space-6);
    }
  }

  .nl-index__list li {
    counter-increment: nl;
    position: relative;
    padding-left: 42px;
  }

  .nl-index__list li::before {
    content: counter(nl, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 2px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-terra-100);
    color: var(--color-terra-700);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    display: grid;
    place-items: center;
  }

  .nl-index__cat {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-green-700);
    background: var(--color-green-100);
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-1);
  }

  .nl-index__name {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0 0 3px;
  }

  .nl-index__desc {
    font-size: 13px;
    line-height: 1.8;
    color: var(--color-ink-mute);
    margin: 0;
  }

  @media (max-width: 768px) {
    .biz { padding: var(--space-5); }
    .biz__num { font-size: 32px; }
    .biz__title { padding-right: 50px; font-size: 18px; }
  }
</style>
