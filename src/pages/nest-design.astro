---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';
---

<BaseLayout
  title="nest Design"
  description="nest Designは、創造性をテーマにした就労継続支援B型事業所です。デザイン実務豊富なスタッフがあなたの才能を引き出します。"
>
  <Hero
    eyebrow="nest Design"
    title="創造性をテーマに、"
    titleSub="あなたの才能を引き出す場所。"
    lead="他の作業所とは一味違うnest独自の支援。常に創造性をテーマとしたワークスペースです。"
    size="lg"
    image="/images/nest-image2/nestdesign_shitsunai.png"
    placeholderLabel="NEST DESIGN — アトリエ / 制作風景"
  />

  <!-- ===== コンセプト ===== -->
  <section class="section">
    <div class="container container--narrow reveal">
      <img
        src="/images/nest-image2/nestdesign-logo.png"
        alt="nest Design"
        width="3087"
        height="2002"
        style="display:block; width:220px; height:auto; margin:0 auto var(--space-5);"
        loading="lazy"
      />
      <span class="eyebrow eyebrow--center">Our Concept</span>
      <h2 class="section__title section__title--center">nest Design のコンセプト</h2>
      <div class="prose">
        <p>
          他の作業所とは一味違うnest独自の支援がネストデザインです。
          単純な軽作業になってしまいがちな就労継続支援B型ではなく、
          常に<strong>創造性をテーマとしたワークスペース</strong>です。
        </p>
        <p>
          絵やデザインが大好きなのに今まであきらめていた方のお手伝いをしたり、
          自分の才能に気づいてない方の感性を引き出せることもあります。
          デザイン実務豊富なスタッフが<strong>基礎から指導できる</strong>こともネストデザインの特徴です。
        </p>
      </div>
    </div>
  </section>

  <!-- ===== 制作作業 ===== -->
  <section class="section section--sand">
    <div class="container">
      <div class="section-head reveal text-center">
        <span class="eyebrow eyebrow--center">Our Works</span>
        <h2 class="section__title section__title--center">制作作業</h2>
        <p class="section__lead section__lead--center">
          オリジナルグッズやアート作品の企画・製作販売、テキスト入力〜校正、
          ネスト〜木町家の販促物・各種印刷物の企画制作、SNS対応まで——
          クリエイティブワーク全般に取り組んでいます。
        </p>
      </div>

      <figure class="works-photo reveal">
        <img
          src="/images/nestdesign-working.png"
          alt="nest Design のアトリエで制作に取り組む利用者の様子"
          loading="lazy"
        />
      </figure>

      <!-- 作品集（利用者の作品を後日掲載予定） -->
      <div class="works-gallery reveal">
        <span class="eyebrow eyebrow--center">Gallery</span>
        <h3 class="works-gallery__title">利用者の作品集は準備中です</h3>
        <p class="works-gallery__note text-soft">
          利用者一人ひとりが生み出した作品を、近日こちらでご紹介します。どうぞお楽しみに。
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section">
    <div class="container">
      <CtaBlock
        title="あなたの才能を、一緒に育てませんか？"
        body="絵やデザインが好きな方、自分の感性を表現したい方の見学・体験を随時受け付けています。"
        primary={{ label: 'お問い合わせフォーム', href: '/contact/' }}
        secondary={{ label: '木町家もチェック', href: '/kimachiya/' }}
        variant="dark"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .prose p { font-size: 16px; line-height: 2; color: var(--color-ink); }
  .prose p + p { margin-top: var(--space-4); }
  .prose strong { color: var(--color-green-900); font-weight: 600; }

  .works-photo {
    max-width: 900px;
    margin: 0 auto var(--space-7);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .works-photo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .works-gallery {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    background: var(--color-paper);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-6);
    box-shadow: var(--shadow-soft);
  }

  .works-gallery__title {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--color-green-900);
    margin: var(--space-2) 0 var(--space-3);
  }

  .works-gallery__note {
    line-height: 1.9;
    font-size: 15px;
  }
</style>
