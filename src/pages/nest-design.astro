---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';
---

<BaseLayout
  title="nestDesign"
  description="nestDesignは、創造性をテーマにした就労継続支援B型事業所です。デザイン実務豊富なスタッフがあなたの才能を引き出します。"
>
  <Hero
    eyebrow="nestDesign"
    title="創造性をテーマに、"
    titleSub="あなたの才能を引き出す場所。"
    lead="他の作業所とは一味違うnest独自の支援。常に創造性をテーマとしたワークスペースです。"
    size="lg"
    image="/images/nest-image2/nestdesign_shitsunai.png"
    placeholderLabel="NEST DESIGN — アトリエ / 制作風景"
  />

  <!-- ===== コンセプト ===== -->
  <section class="section">
    <div class="container container--narrow reveal">
      <div class="nd-logo-row">
        <img
          class="nd-logo"
          src="/images/nest-image2/nestdesign-logo.png"
          alt="nestDesign"
          width="3087"
          height="2002"
          loading="lazy"
        />
        <img
          class="nd-mentor"
          src="/images/nestdesign-mentor.jpg"
          alt="nestDesignで利用者を指導するベテランデザイナー"
          width="1024"
          height="1536"
          loading="lazy"
        />
      </div>
      <span class="eyebrow eyebrow--center">Our Concept</span>
      <h2 class="section__title section__title--center">個性を描く、おもちゃ箱のアトリエ</h2>
      <div class="prose">
        <p>
          nestDesign は、福祉という枠組みを超え、一人ひとりの感性をアートとして社会へ届ける
          <strong>クリエイティブ・アトリエ</strong>です。「福祉の事業所だから」という応援ではなく、
          作品そのものが持つ力で、見る人の心を動かす——私たちは、そんな新しい福祉の価値を創造しています。
        </p>
      </div>
      <ul class="nd-points">
        <li>
          <strong>唯一無二の感性を、デザインの力で</strong>
          <span>
            メンバーが紡ぎ出す、個性あふれる線や色。そこにプロの視点で「少しの工夫」を添え、
            日常を彩るアートへと昇華させます。オリジナリティを尊重し、手に取った人の心に温かな驚きを届ける——
            デザイン実務豊富なスタッフが、基礎から伴走します。
          </span>
        </li>
        <li>
          <strong>自然体でいられる「おもちゃ箱」</strong>
          <span>
            アトリエに堅苦しさはありません。BGMが流れ、誰もが自分のペースで創作を楽しむ。
            そんな心地よい「居場所」から、枠にとらわれない自由な創造性が生まれています。
          </span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ===== 制作作業 ===== -->
  <section class="section section--sand">
    <div class="container">
      <div class="section-head reveal text-center">
        <span class="eyebrow eyebrow--center">Our Works</span>
        <h2 class="section__title section__title--center">制作作業</h2>
        <p class="section__lead section__lead--center">
          オリジナルグッズやアート作品の企画・制作販売、テキスト入力〜校正、
          ネスト〜木町家の販促物・各種印刷物の企画制作、SNS対応まで——
          創作の輪を広げながら、日常に小さなアートを届けています。
        </p>
      </div>

      <ul class="nd-points nd-points--works reveal">
        <li>
          <strong>イラスト傘</strong>
          <span>一点ずつメンバーが手描きする、世界に一つだけのパートナー。</span>
        </li>
        <li>
          <strong>卵パックの湿気取り</strong>
          <span>コーヒーかすとリサイクル紙でつくる、エコで愛らしい暮らしの相棒。</span>
        </li>
        <li>
          <strong>日常を彩る創作活動</strong>
          <span>カレンダー制作や空間装飾など、暮らしの中に小さなアートを広げています。</span>
        </li>
      </ul>

      <figure class="works-photo reveal">
        <img
          src="/images/nestdesign-working.png"
          alt="nestDesign のアトリエで制作に取り組む利用者の様子"
          loading="lazy"
        />
      </figure>

      <!-- 作品集（利用者の作品を後日掲載予定） -->
      <div class="works-gallery reveal">
        <span class="eyebrow eyebrow--center">Gallery</span>
        <h3 class="works-gallery__title">利用者の作品集は準備中です</h3>
        <p class="works-gallery__note text-soft">
          利用者一人ひとりが生み出した作品を、近日こちらでご紹介します。どうぞお楽しみに。
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section">
    <div class="container">
      <CtaBlock
        title="あなたの才能を、一緒に育てませんか？"
        body="絵やデザインが好きな方、自分の感性を表現したい方の見学・体験を随時受け付けています。"
        primary={{ label: 'お問い合わせフォーム', href: '/contact/' }}
        secondary={{ label: '木町家もチェック', href: '/kimachiya/' }}
        variant="dark"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .prose p { font-size: 16px; line-height: 2; color: var(--color-ink); }
  .prose p + p { margin-top: var(--space-4); }
  .prose strong { color: var(--color-green-900); font-weight: 600; }

  /* CONCEPT / WORKS の要点。左にテラコッタの罫を引いたエディトリアルなリスト。 */
  .nd-points {
    list-style: none;
    max-width: 760px;
    margin: var(--space-6) auto 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .nd-points li {
    padding-left: var(--space-5);
    border-left: 3px solid var(--color-terra-500);
  }

  .nd-points strong {
    display: block;
    font-family: var(--font-hand);
    font-size: 18px;
    color: var(--color-green-900);
    margin-bottom: var(--space-2);
  }

  .nd-points span {
    display: block;
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-ink);
  }

  /* WORKS は3点を横並びのカード状に。狭い画面では縦積み。 */
  .nd-points--works {
    max-width: 920px;
    margin-bottom: var(--space-7);
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 720px) {
    .nd-points--works { grid-template-columns: 1fr; }
  }

  .works-photo {
    max-width: 900px;
    margin: 0 auto var(--space-7);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .works-photo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .works-gallery {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    background: var(--color-paper);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-6);
    box-shadow: var(--shadow-soft);
  }

  .works-gallery__title {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--color-green-900);
    margin: var(--space-2) 0 var(--space-3);
  }

  .works-gallery__note {
    line-height: 1.9;
    font-size: 15px;
  }

  /* ロゴと、指導役のベテランデザイナー（人形）を横並びに */
  .nd-logo-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    flex-wrap: wrap;
    margin-bottom: var(--space-5);
  }

  .nd-logo-row .nd-logo {
    display: block;
    width: 220px;
    height: auto;
  }

  /* 約3cm四方（≒120px）。縦長画像なので高さ基準で揃える。 */
  .nd-logo-row .nd-mentor {
    display: block;
    width: auto;
    height: 120px;
  }
</style>
