---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';
import { site } from '../lib/site';

const features = [
  {
    image: '/images/kimachiya-cooking.jpg',
    title: '利用者とともに作る手作り料理',
    body: '基本コンセプトは『わが子に食べさせたい味』。四季折々の新鮮食材をひと手間かけてご提供しています。',
  },
  {
    image: '/images/kimachiya-bread.jpg',
    title: 'ヘルシー！オリジナル米粉パン',
    body: '北九州ではここだけのオリジナル米粉パン。油の吸収率が低く、消化しやすいのが特徴です。',
  },
  {
    image: '/images/kimachiya-sweets.jpg',
    title: '絶品！手づくりスイーツ',
    body: 'ていねいに作られたシフォンケーキやスイーツ。木の温もりと手づくりの味わいの中でお楽しみいただけます。',
  },
  {
    image: '/images/kimachiya-marche.jpg',
    title: 'いろいろ楽しい毎日マルシェ！',
    body: '提携農場の新鮮野菜や、つくり手の顔が見える惣菜、山や海の幸を提供しています。',
  },
];
---

<BaseLayout
  title="キッチン＆マルシェ 木町家"
  description="キッチン＆マルシェ木町家は、北九州市小倉北区の就労継続支援B型事業所です。南小倉駅前で美味しいお料理をご提供しています。"
>
  <Hero
    eyebrow="Kimachi-ya"
    title="美味しくて、<br />ほっとする味を、"
    titleSub="南小倉駅のすぐそばで。"
    lead="キッチン＆マルシェ木町家 — 就労継続支援B型事業所"
    size="lg"
    image="/images/nest-image1/kimachiyayukei.png"
    placeholderLabel="KIMACHI-YA — 厨房 / 料理 / 米粉パン"
  />

  <!-- ===== コンセプト ===== -->
  <section class="section">
    <div class="container container--narrow reveal">
      <img
        src="/images/nest-image1/kimachiya-logo.png"
        alt="キッチン＆マルシェ 木町家"
        width="1858"
        height="1159"
        style="display:block; width:210px; height:auto; margin:0 auto var(--space-5);"
        loading="lazy"
      />
      <span class="eyebrow eyebrow--center">Our Concept</span>
      <h2 class="section__title section__title--center">木町家について</h2>
      <p style="font-size:16px; line-height:2; color:var(--color-ink);">
        『木町家』は就労継続支援B型の障がい福祉サービス事業所です。
        お客様にはいろいろとご面倒をおかけすると思いますが、その分どこよりも美味しく安心安全なお料理をご提供致します。<br />
        手づくりウエディングなどの集いの席、各種イベント、作品展、ギャラリー、ミニライブなどにもご利用いただけます。
      </p>
    </div>
  </section>

  <!-- ===== 特徴 ===== -->
  <section class="section section--sand">
    <div class="container">
      <div class="section-head reveal text-center">
        <span class="eyebrow eyebrow--center">Four Highlights</span>
        <h2 class="section__title section__title--center">木町家の4つの特徴</h2>
      </div>

      <div class="features">
        {
          features.map((f, i) => (
            <article class="feature reveal" data-delay={(i % 4) + 1}>
              <div class="feature__media">
                <img
                  class="feature__img"
                  src={f.image}
                  alt={f.title}
                  loading="lazy"
                />
                <span class="feature__num">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="feature__text">
                <h3 class="feature__title">{f.title}</h3>
                <p class="feature__body">{f.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Instagram ===== -->
  <section class="section ig-section">
    <div class="container container--narrow">
      <a
        href={site.instagram}
        class="ig-cta reveal"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="木町家の Instagram（@kimachi_ya）を新しいタブで開く"
      >
        <span class="ig-cta__glyph" aria-hidden="true">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6" />
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6" />
            <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" />
          </svg>
        </span>
        <span class="eyebrow eyebrow--center">Instagram</span>
        <h2 class="ig-cta__title">日々のメニュー・マルシェ情報はこちら</h2>
        <p class="ig-cta__lead">
          木町家の手づくり料理や米粉パン、季節のマルシェの様子を発信しています。
          フォローして、最新の情報をチェックしてください。
        </p>
        <span class="btn btn--accent btn--lg ig-cta__btn">
          @kimachi_ya をフォロー
          <span class="btn__icon" aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </section>

  <!-- ===== 営業情報 ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal text-center">
        <span class="eyebrow eyebrow--center">Hours & Access</span>
        <h2 class="section__title section__title--center">営業情報</h2>
      </div>

      <a
        href="https://www.google.com/maps/search/?api=1&query=福岡県北九州市小倉北区木町3丁目9-15"
        target="_blank"
        rel="noopener"
        class="kimachiya-map reveal"
        aria-label="Googleマップでキッチン＆マルシェ木町家の周辺を開く"
      >
        <img
          src="/images/nest-image2/nestmap.gif"
          alt="キッチン＆マルシェ木町家 周辺の案内地図。最寄りはJR南小倉駅。"
          width="925"
          height="745"
          loading="lazy"
        />
      </a>

      <div class="grid-2" style="margin-top:48px;">
        <div class="info-box reveal">
          <div class="info-box__title">☀️ 日中営業について</div>
          <dl>
            <dt>営業時間</dt>
            <dd>AM11:00〜PM3:00</dd>
            <dt>営業日</dt>
            <dd>月・火・水・木・金・第3土曜日</dd>
            <dt>ご予約・お問い合わせ</dt>
            <dd><a href="tel:0935920331">093-592-0331</a></dd>
            <dt>住所</dt>
            <dd>北九州市小倉北区木町3丁目9-15<br>南小倉駅前 徒歩1分</dd>
          </dl>
        </div>

        <div class="info-box reveal" data-delay="1">
          <div class="info-box__title">🌙 夜間営業について</div>
          <dl>
            <dt>営業時間</dt>
            <dd>PM6:30〜PM9:00の間で <strong>90分</strong></dd>
            <dt>ご利用条件</dt>
            <dd>4名様以上・完全予約制・<strong>2日前まで</strong>に要予約・<strong>予算１０万円以上</strong></dd>
            <dt>定休日</dt>
            <dd>土曜日・日曜日（第3土曜日を除く）</dd>
            <dt>郵便番号</dt>
            <dd>〒803-0851</dd>
          </dl>
          <p style="margin-top:var(--space-4); font-size:14px; color:var(--color-ink-mute);">なお詳細については、ご相談ください。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section section--sand">
    <div class="container">
      <CtaBlock
        title="見学・体験ご希望の方へ"
        body="就労継続支援B型のご利用をご検討中の方は、お気軽にお問い合わせください。"
        primary={{ label: 'お問い合わせフォーム', href: '/contact/' }}
        secondary={{ label: '利用者募集の詳細', href: '/recruit/' }}
        variant="dark"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  .feature {
    background-color: var(--color-paper);
    border-radius: var(--radius-lg);
    position: relative;
    overflow: hidden;
    transition: transform var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out);
    box-shadow: var(--shadow-soft);
  }

  .feature:hover { transform: translateY(-4px); box-shadow: var(--shadow-hi); }

  .feature__media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .feature__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow, 0.6s) var(--ease-out);
  }

  .feature:hover .feature__img { transform: scale(1.04); }

  .feature__num {
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-paper);
    letter-spacing: 0.1em;
    background-color: rgba(31, 42, 28, 0.55);
    padding: 2px 10px;
    border-radius: 999px;
    backdrop-filter: blur(2px);
  }

  .feature__text {
    padding: var(--space-6) var(--space-6) var(--space-7);
  }

  .feature__title {
    font-family: var(--font-serif);
    font-size: 20px;
    color: var(--color-green-900);
    margin-bottom: var(--space-3);
  }

  .feature__body {
    color: var(--color-ink-mute);
    line-height: 1.85;
    font-size: 14px;
  }

  /* === Instagram 誘導 === */
  .ig-section {
    background-color: var(--color-cream);
    background-image:
      radial-gradient(circle at 12% 18%, rgba(217, 119, 87, 0.08), transparent 42%),
      radial-gradient(circle at 88% 82%, rgba(74, 140, 63, 0.08), transparent 42%);
  }

  .ig-cta {
    display: block;
    max-width: 620px;
    margin: 0 auto;
    background: var(--color-paper);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: var(--space-8) var(--space-7);
    text-align: center;
    transition: transform var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out);
  }

  .ig-cta:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hi);
  }

  .ig-cta:hover .btn__icon { transform: translateX(4px); }

  .ig-cta__glyph {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    margin: 0 auto var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: linear-gradient(135deg, var(--color-green-700), var(--color-terra-500));
  }

  .ig-cta__title {
    font-family: var(--font-serif);
    font-size: var(--fs-h3);
    color: var(--color-green-900);
    line-height: 1.5;
    margin-bottom: var(--space-3);
  }

  .ig-cta__lead {
    color: var(--color-ink-mute);
    line-height: 1.9;
    font-size: 15px;
    margin-bottom: var(--space-6);
  }

  .ig-cta__btn { pointer-events: none; }

  .kimachiya-map {
    display: block;
    max-width: 760px;
    margin: var(--space-6) auto 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: transform var(--dur-base) var(--ease-out),
                box-shadow var(--dur-base) var(--ease-out);
  }

  .kimachiya-map:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .kimachiya-map img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 880px) {
    .features { grid-template-columns: 1fr; }
    .ig-cta { padding: var(--space-7) var(--space-5); }
  }
</style>
