---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import IframePlaceholder from '../components/IframePlaceholder.astro';
import { site } from '../lib/site';
import { renderSVG } from 'uqr';

// ───────────────────────────────────────────────────────────────
// Google フォームの公開URL。
// scripts/create-nest-inquiry-form.gs を実行すると発行される「公開URL」を
// ここに貼り付けると、埋め込みフォームと QR コードが本番表示に切り替わります。
// 例: 'https://docs.google.com/forms/d/e/XXXXXXXXXXXX/viewform'
// 空のままなら「準備中」表示になります。
const FORM_VIEW_URL = '';
// ───────────────────────────────────────────────────────────────

const isFormReady = FORM_VIEW_URL.length > 0;
const formEmbedUrl = isFormReady
  ? FORM_VIEW_URL + (FORM_VIEW_URL.includes('?') ? '&' : '?') + 'embedded=true'
  : '';

// QR コードをビルド時に SVG として生成（第三者サービス不使用・インライン埋め込み）
const qrSvg = isFormReady
  ? renderSVG(FORM_VIEW_URL, { blackColor: '#102211', whiteColor: 'transparent', border: 0 })
  : '';
---

<BaseLayout
  title="お問い合わせ"
  description="NPO法人nestへのお問い合わせはこちらから。見学・体験のご相談もお気軽にどうぞ。"
>
  <Hero
    eyebrow="Contact"
    title="お問い合わせ"
    lead="ご相談・お問い合わせは、事務局まで。お電話またはフォームより、お気軽にどうぞ。"
    size="md"
    image="/images/nest-image1/kimachiya-gaikan.png"
    placeholderLabel="CONTACT"
  />

  <!-- フォーム -->
  <section class="section" aria-labelledby="form-title">
    <div class="container">
      <div class="contact-grid">

        <aside class="contact-side reveal">
          <span class="eyebrow">Direct</span>
          <h2 class="contact-side__title">お電話でも<br />お気軽にどうぞ</h2>
          <a href={`tel:${site.tel.replaceAll('-', '')}`} class="contact-side__tel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            </svg>
            <span class="contact-side__tel-num">{site.tel}</span>
          </a>
          <p class="contact-side__hours">電話受付：{site.telHours}</p>
          <p class="contact-side__holiday">{site.telHoliday}</p>
          <p class="contact-side__fax">FAX：{site.tel}</p>

          <div class="contact-side__topics">
            <h3 class="contact-side__topics-title">よくあるお問い合わせ</h3>
            <ul>
              <li>就労継続支援B型の見学・体験</li>
              <li>グループホームの空き状況</li>
              <li>入会・寄付・ボランティアについて</li>
              <li>取材・講演のご依頼</li>
            </ul>
          </div>

          <div class="contact-side__qr">
            <h3 class="contact-side__topics-title">スマホで読み取る</h3>
            {isFormReady ? (
              <>
                <div class="contact-side__qr-img"><Fragment set:html={qrSvg} /></div>
                <p class="contact-side__qr-note">QRコードを読み取ると、お問い合わせフォームを開けます。</p>
              </>
            ) : (
              <>
                <div class="contact-side__qr-img contact-side__qr-img--ph" aria-hidden="true">準備中</div>
                <p class="contact-side__qr-note">フォーム公開後、ここにQRコードを表示します。</p>
              </>
            )}
          </div>
        </aside>

        <div class="contact-form reveal" data-delay="1">
          <span class="eyebrow">Inquiry Form</span>
          <h2 id="form-title" class="contact-form__title">お問い合わせフォーム</h2>
          <p class="contact-form__lead">
            下記フォームよりお問い合わせください。担当者より後日ご連絡いたします。
          </p>
          {isFormReady ? (
            <div class="contact-form__embed">
              <iframe
                src={formEmbedUrl}
                title="nest お問い合わせフォーム"
                loading="lazy"
                width="100%"
                height="900"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
              >読み込んでいます…</iframe>
            </div>
          ) : (
            <IframePlaceholder
              icon="📋"
              title="お問い合わせフォーム（準備中）"
              note="Googleフォームの公開URLを設定すると、ここにフォームが表示されます。設定方法は scripts/create-nest-inquiry-form.gs を参照。"
              minHeight="540px"
            />
          )}
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: var(--space-7);
    align-items: start;
  }

  .contact-side {
    background-color: var(--color-paper);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
    box-shadow: var(--shadow-soft);
    position: sticky;
    top: 100px;
  }

  .contact-side__title {
    font-family: var(--font-serif);
    font-size: 24px;
    color: var(--color-green-900);
    margin-bottom: var(--space-5);
    line-height: 1.5;
  }

  .contact-side__tel {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-green-900);
    margin-bottom: var(--space-3);
  }

  .contact-side__tel-num {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .contact-side__tel:hover {
    color: var(--color-terra-500);
  }

  .contact-side__hours,
  .contact-side__fax {
    font-size: 13px;
    color: var(--color-ink-mute);
    margin: 4px 0;
  }

  .contact-side__holiday {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-terra-500);
    margin: 4px 0;
  }

  .contact-side__topics {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-line);
  }

  .contact-side__topics-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-terra-500);
    margin-bottom: var(--space-4);
  }

  .contact-side__topics ul {
    list-style: none;
    padding: 0;
  }

  .contact-side__topics li {
    font-size: 13px;
    color: var(--color-ink);
    padding: var(--space-2) 0;
    border-bottom: 1px dotted var(--color-line);
    position: relative;
    padding-left: 16px;
  }

  .contact-side__topics li::before {
    content: '・';
    position: absolute;
    left: 0;
    color: var(--color-green-700);
  }

  .contact-side__qr {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-line);
  }

  .contact-side__qr-img {
    width: 148px;
    height: 148px;
    margin-top: var(--space-2);
    padding: 12px;
    background: #fff;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .contact-side__qr-img :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .contact-side__qr-img--ph {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream);
    color: var(--color-ink-soft);
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.1em;
    box-shadow: none;
  }

  .contact-side__qr-note {
    font-size: 12px;
    color: var(--color-ink-mute);
    line-height: 1.7;
    margin-top: var(--space-3);
  }

  .contact-form__title {
    font-family: var(--font-serif);
    font-size: 26px;
    color: var(--color-green-900);
    margin-bottom: var(--space-3);
  }

  .contact-form__lead {
    color: var(--color-ink-mute);
    margin-bottom: var(--space-5);
  }

  .contact-form__embed {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    background: #fff;
  }

  .contact-form__embed iframe {
    display: block;
    width: 100%;
    border: 0;
  }

  @media (max-width: 980px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-side { position: static; }
  }
</style>
