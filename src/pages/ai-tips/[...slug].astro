---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('aiTips', ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const fmtDate = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
---

<BaseLayout title={item.data.title} description={item.data.summary ?? item.data.title}>
  <article class="tip-article">
    <div class="container container--narrow">
      <header class="tip-article__head reveal">
        <a href="/ai-tips/" class="tip-article__back">
          <span aria-hidden="true">←</span> 教えてAIさん 一覧へ
        </a>
        <span class="badge badge--accent">教えてAIさん</span>
        <h1 class="tip-article__title">{item.data.title}</h1>
        <time class="tip-article__date" datetime={item.data.date.toISOString()}>
          {fmtDate(item.data.date)}
        </time>
      </header>

      <div class="tip-article__body reveal">
        <Content />
      </div>

      <div class="tip-article__foot reveal">
        <a href="/ai-tips/" class="btn btn--outline">一覧に戻る</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tip-article {
    padding-block: var(--space-9) var(--space-8);
  }

  .tip-article__head {
    text-align: center;
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-line);
  }

  .tip-article__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 13px;
    color: var(--color-ink-mute);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-5);
  }

  .tip-article__back:hover { color: var(--color-terra-500); }

  .tip-article__title {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 600;
    color: var(--color-green-900);
    line-height: 1.5;
    margin-block: var(--space-4);
  }

  .tip-article__date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
  }

  .tip-article__body {
    font-size: 16px;
    line-height: 2;
    color: var(--color-ink);
  }

  .tip-article__body :global(p) { margin-bottom: var(--space-5); }
  .tip-article__body :global(h2) {
    font-size: 22px;
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
    color: var(--color-green-900);
  }
  .tip-article__body :global(h3) {
    font-size: 18px;
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
    color: var(--color-green-900);
  }
  .tip-article__body :global(ul),
  .tip-article__body :global(ol) {
    padding-left: 1.6em;
    margin-bottom: var(--space-5);
  }
  .tip-article__body :global(ul) { list-style: disc; }
  .tip-article__body :global(ol) { list-style: decimal; }
  .tip-article__body :global(li) { margin-bottom: var(--space-2); }
  .tip-article__body :global(a) {
    color: var(--color-green-700);
    border-bottom: 1px solid currentColor;
  }
  .tip-article__body :global(a:hover) {
    color: var(--color-terra-500);
  }
  .tip-article__body :global(strong) {
    color: var(--color-green-900);
    font-weight: 600;
  }
  .tip-article__body :global(img) {
    max-width: 100%;
    height: auto;
  }

  /* AIとの会話ふきだし */
  .tip-article__body :global(.qa) {
    margin: var(--space-6) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .tip-article__body :global(.qa__row) {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .tip-article__body :global(.qa__row--ai) { flex-direction: row-reverse; }
  .tip-article__body :global(.qa__avatar) {
    flex: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    line-height: 1;
  }
  .tip-article__body :global(.qa__row--me .qa__avatar) {
    background: var(--color-cream);
    border: 1px solid var(--color-line);
  }
  .tip-article__body :global(.qa__row--ai .qa__avatar) {
    background: var(--color-green-700);
  }
  .tip-article__body :global(.qa__bubble) {
    position: relative;
    max-width: 78%;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    font-size: 15px;
    line-height: 1.85;
    margin: 0;
  }
  .tip-article__body :global(.qa__row--me .qa__bubble) {
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-top-left-radius: 4px;
  }
  .tip-article__body :global(.qa__row--ai .qa__bubble) {
    background: rgba(74, 140, 63, 0.1);
    border: 1px solid rgba(74, 140, 63, 0.25);
    border-top-right-radius: 4px;
  }

  /* キーボードのキー表示 */
  .tip-article__body :global(.kbd) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.9em;
    padding: 0.2em 0.55em;
    margin: 0 0.12em;
    font-family: var(--font-mono);
    font-size: 0.88em;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-green-900);
    background: linear-gradient(180deg, #ffffff, #efe4cf);
    border: 1px solid var(--color-line);
    border-bottom-width: 3px;
    border-radius: 8px;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    white-space: nowrap;
  }

  /* ショートカットの図（キーを大きく見せる） */
  .tip-article__body :global(.kbd-figure) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.45em;
    margin: var(--space-5) 0;
    padding: var(--space-5);
    background: var(--color-cream);
    border: 1px dashed var(--color-green-700);
    border-radius: var(--radius-lg);
  }
  .tip-article__body :global(.kbd-figure .kbd) {
    font-size: 1.2em;
    padding: 0.45em 0.85em;
  }
  .tip-article__body :global(.kbd-figure .kbd-plus) {
    font-size: 1.15em;
    font-weight: 700;
    color: var(--color-ink-mute);
  }
  .tip-article__body :global(.kbd-figure figcaption) {
    flex-basis: 100%;
    text-align: center;
    margin-top: var(--space-3);
    font-size: 13px;
    color: var(--color-ink-mute);
  }

  /* 画面イメージ図 */
  .tip-article__body :global(.mockup) {
    margin: var(--space-6) auto;
    text-align: center;
  }
  .tip-article__body :global(.mockup img) {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: var(--radius-md);
  }
  .tip-article__body :global(.mockup--wide img) { max-width: 580px; }
  .tip-article__body :global(.mockup--shot img) {
    box-shadow: var(--shadow-soft);
    border: 1px solid var(--color-line);
  }

  /* AIへの頼み方（コピペ用の例文ボックス） */
  .tip-article__body :global(.ai-prompt) {
    margin: var(--space-5) 0;
    padding: var(--space-4) var(--space-5);
    background: rgba(74, 140, 63, 0.08);
    border-left: 4px solid var(--color-green-700);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-ink);
  }
  .tip-article__body :global(.ai-prompt__label) {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-terra-500);
    margin-bottom: var(--space-2);
  }

  /* 補足ボックス（中級者向け・参考／注意など） */
  .tip-article__body :global(.callout) {
    margin: var(--space-5) 0;
    padding: var(--space-4) var(--space-5);
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  .tip-article__body :global(.callout > :last-child) { margin-bottom: 0; }
  .tip-article__body :global(.callout__label) {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #fff;
    background: var(--color-terra-500);
    padding: 3px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-3);
  }
  .tip-article__body :global(.mockup figcaption) {
    margin-top: var(--space-2);
    font-size: 12px;
    color: var(--color-ink-mute);
  }

  /* できあがったスライドの一覧（2列グリッド） */
  .tip-article__body :global(.slide-gallery) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin: var(--space-6) 0;
  }
  .tip-article__body :global(.slide-gallery figure) { margin: 0; }
  .tip-article__body :global(.slide-gallery img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
  }
  .tip-article__body :global(.slide-gallery figcaption) {
    margin-top: 6px;
    font-size: 12px;
    color: var(--color-ink-mute);
    text-align: center;
  }
  @media (max-width: 560px) {
    .tip-article__body :global(.slide-gallery) { grid-template-columns: 1fr; }
  }

  /* プロンプト配布ボックス（コピー・保存つき） */
  .tip-article__body :global(.prompt-share) {
    margin: var(--space-6) 0;
    border: 1px solid var(--color-green-700);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #fff;
  }
  .tip-article__body :global(.prompt-share__cap) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: rgba(74, 140, 63, 0.1);
    border-bottom: 1px solid rgba(74, 140, 63, 0.25);
  }
  .tip-article__body :global(.prompt-share__title) {
    font-weight: 600;
    color: var(--color-green-900);
    font-size: 15px;
  }
  .tip-article__body :global(.prompt-share__meta) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-mute);
  }
  .tip-article__body :global(.prompt-share__body) {
    margin: 0;
    padding: var(--space-4) var(--space-5);
    max-height: 300px;
    overflow: auto;
    background: var(--color-cream);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.8;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .tip-article__body :global(.prompt-share__actions) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--color-line);
  }
  .tip-article__body :global(.prompt-share__btn) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    border: 1px solid var(--color-green-700);
    background: var(--color-green-700);
    color: #fff;
    transition: background .15s ease, color .15s ease, border-color .15s ease;
  }
  .tip-article__body :global(.prompt-share__btn:hover) { background: var(--color-green-900); border-color: var(--color-green-900); }
  .tip-article__body :global(.prompt-share__btn.copied) { background: var(--color-terra-500); border-color: var(--color-terra-500); }
  .tip-article__body :global(.prompt-share__btn--ghost) {
    background: transparent;
    color: var(--color-green-700);
    border-bottom: 1px solid var(--color-green-700);
  }
  .tip-article__body :global(.prompt-share__btn--ghost:hover) { background: rgba(74, 140, 63, 0.08); color: var(--color-green-900); }

  .tip-article__foot {
    margin-top: var(--space-8);
    text-align: center;
  }

  @media (max-width: 768px) {
    .tip-article__title { font-size: 22px; }
    .tip-article__body :global(.qa__bubble) { max-width: 100%; }
  }
</style>

<script>
  // プロンプト配布ボックス：本文プレビューの読み込みと、コピー／保存ボタン
  const promptCache = new Map<string, Promise<string>>();
  const fetchPrompt = (src: string) => {
    if (!promptCache.has(src)) {
      promptCache.set(src, fetch(src).then((r) => (r.ok ? r.text() : Promise.reject(r.status))));
    }
    return promptCache.get(src)!;
  };

  const copyText = (text: string): Promise<boolean> => {
    if (navigator.clipboard?.writeText) {
      return navigator.clipboard.writeText(text).then(() => true, () => fallbackCopy(text));
    }
    return Promise.resolve(fallbackCopy(text));
  };
  const fallbackCopy = (text: string): boolean => {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:-1000px;opacity:0';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    let ok = false;
    try { ok = document.execCommand('copy'); } catch (e) { ok = false; }
    document.body.removeChild(ta);
    return ok;
  };

  // 本文プレビューを読み込む
  document.querySelectorAll<HTMLElement>('[data-prompt-src]').forEach((el) => {
    const src = el.dataset.promptSrc!;
    fetchPrompt(src).then(
      (text) => { el.textContent = text; },
      () => { el.textContent = 'プレビューを読み込めませんでした。下の「テキストで保存」からダウンロードしてご利用ください。'; }
    );
  });

  // コピーボタン
  document.querySelectorAll<HTMLButtonElement>('[data-copy-src]').forEach((btn) => {
    const src = btn.dataset.copySrc!;
    const label = btn.textContent;
    btn.addEventListener('click', () => {
      fetchPrompt(src)
        .then((text) => copyText(text))
        .then((ok) => {
          btn.textContent = ok ? 'コピーしました' : 'コピーできませんでした';
          if (ok) btn.classList.add('copied');
          setTimeout(() => { btn.textContent = label; btn.classList.remove('copied'); }, 1800);
        })
        .catch(() => {
          btn.textContent = 'コピーできませんでした';
          setTimeout(() => { btn.textContent = label; }, 1800);
        });
    });
  });
</script>
