---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('aiTips', ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const fmtDate = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
---

<BaseLayout title={item.data.title} description={item.data.summary ?? item.data.title}>
  <article class="tip-article">
    <div class="container container--narrow">
      <header class="tip-article__head reveal">
        <a href="/ai-tips/" class="tip-article__back">
          <span aria-hidden="true">←</span> 教えてAIさん 一覧へ
        </a>
        <span class="badge badge--accent">教えてAIさん</span>
        <h1 class="tip-article__title">{item.data.title}</h1>
        <time class="tip-article__date" datetime={item.data.date.toISOString()}>
          {fmtDate(item.data.date)}
        </time>
      </header>

      <div class="tip-article__body reveal">
        <Content />
      </div>

      <div class="tip-article__foot reveal">
        <a href="/ai-tips/" class="btn btn--outline">一覧に戻る</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tip-article {
    padding-block: var(--space-9) var(--space-8);
  }

  .tip-article__head {
    text-align: center;
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-line);
  }

  .tip-article__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 13px;
    color: var(--color-ink-mute);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-5);
  }

  .tip-article__back:hover { color: var(--color-terra-500); }

  .tip-article__title {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 600;
    color: var(--color-green-900);
    line-height: 1.5;
    margin-block: var(--space-4);
  }

  .tip-article__date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
  }

  .tip-article__body {
    font-size: 16px;
    line-height: 2;
    color: var(--color-ink);
  }

  .tip-article__body :global(p) { margin-bottom: var(--space-5); }
  .tip-article__body :global(h2) {
    font-size: 22px;
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
    color: var(--color-green-900);
  }
  .tip-article__body :global(h3) {
    font-size: 18px;
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
    color: var(--color-green-900);
  }
  .tip-article__body :global(ul),
  .tip-article__body :global(ol) {
    padding-left: 1.6em;
    margin-bottom: var(--space-5);
  }
  .tip-article__body :global(ul) { list-style: disc; }
  .tip-article__body :global(ol) { list-style: decimal; }
  .tip-article__body :global(li) { margin-bottom: var(--space-2); }
  .tip-article__body :global(a) {
    color: var(--color-green-700);
    border-bottom: 1px solid currentColor;
  }
  .tip-article__body :global(a:hover) {
    color: var(--color-terra-500);
  }
  .tip-article__body :global(strong) {
    color: var(--color-green-900);
    font-weight: 600;
  }
  .tip-article__body :global(img) {
    max-width: 100%;
    height: auto;
  }

  /* AIとの会話ふきだし */
  .tip-article__body :global(.qa) {
    margin: var(--space-6) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .tip-article__body :global(.qa__row) {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .tip-article__body :global(.qa__row--ai) { flex-direction: row-reverse; }
  .tip-article__body :global(.qa__avatar) {
    flex: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    line-height: 1;
  }
  .tip-article__body :global(.qa__row--me .qa__avatar) {
    background: var(--color-cream);
    border: 1px solid var(--color-line);
  }
  .tip-article__body :global(.qa__row--ai .qa__avatar) {
    background: var(--color-green-700);
  }
  .tip-article__body :global(.qa__bubble) {
    position: relative;
    max-width: 78%;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    font-size: 15px;
    line-height: 1.85;
    margin: 0;
  }
  .tip-article__body :global(.qa__row--me .qa__bubble) {
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-top-left-radius: 4px;
  }
  .tip-article__body :global(.qa__row--ai .qa__bubble) {
    background: rgba(74, 140, 63, 0.1);
    border: 1px solid rgba(74, 140, 63, 0.25);
    border-top-right-radius: 4px;
  }

  .tip-article__foot {
    margin-top: var(--space-8);
    text-align: center;
  }

  @media (max-width: 768px) {
    .tip-article__title { font-size: 22px; }
    .tip-article__body :global(.qa__bubble) { max-width: 100%; }
  }
</style>
