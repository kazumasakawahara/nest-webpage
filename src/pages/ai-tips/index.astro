---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const all = await getCollection('aiTips', ({ data }) => !data.draft);
const items = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<BaseLayout
  title="教えてAIさん"
  description="福祉の現場で役立つ、PC・AIの便利な使い方を「AIに聞いてみた」かたちでご紹介します。"
>
  <Hero
    eyebrow="教えてAIさん"
    title="AIに聞いてみた、<br />現場のちょっとした便利ワザ"
    lead="「パソコンやAIで、こんなことができるの？」——福祉の現場や暮らしで役立つコツを、AIに教わりながら少しずつ積み重ねていきます。"
    size="md"
    image="/images/ai-tips-hero.svg"
    imagePosition="center right"
    bright={true}
  />

  <section class="section">
    <div class="container container--narrow">
      {items.length > 0 ? (
        <ul class="tips-list">
          {items.map((item, i) => (
            <li class="tips-list__item reveal" data-delay={(i % 3) + 1}>
              <a href={`/ai-tips/${item.id}/`} class="tips-list__link">
                <time class="tips-list__date" datetime={item.data.date.toISOString()}>
                  {fmtDate(item.data.date)}
                </time>
                <h3 class="tips-list__title">{item.data.title}</h3>
                {item.data.summary && (
                  <p class="tips-list__summary">{item.data.summary}</p>
                )}
                <span class="tips-list__arrow" aria-hidden="true">
                  <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
                    <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-soft text-center">記事は準備中です。もうしばらくお待ちください。</p>
      )}

      <p class="text-soft text-center" style="margin-top:var(--space-7);">
        ※ このページは担当スタッフが随時更新します（Markdown ファイルを <code>src/content/ai-tips/</code> に追加するだけで反映）。
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .tips-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    padding: 0;
  }

  .tips-list__item {
    border-top: 1px solid var(--color-line);
  }

  .tips-list__item:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .tips-list__link {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-4);
    color: var(--color-ink);
    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .tips-list__link:hover {
    background-color: rgba(74, 140, 63, 0.04);
    color: var(--color-ink);
  }

  .tips-list__date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
  }

  .tips-list__title {
    font-family: var(--font-hand);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-green-900);
    line-height: 1.6;
  }

  .tips-list__summary {
    grid-column: 2;
    font-size: 13px;
    color: var(--color-ink-mute);
    margin-top: var(--space-2);
  }

  .tips-list__arrow {
    color: var(--color-green-700);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .tips-list__link:hover .tips-list__arrow {
    transform: translateX(4px);
    color: var(--color-terra-500);
  }

  @media (max-width: 720px) {
    .tips-list__link {
      grid-template-columns: 1fr;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-3);
    }
    .tips-list__summary { grid-column: 1; }
    .tips-list__arrow { display: none; }
  }
</style>
