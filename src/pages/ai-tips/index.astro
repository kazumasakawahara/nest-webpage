---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import AiTipsQuestionBox from '../../components/AiTipsQuestionBox.astro';

const all = await getCollection('aiTips', ({ data }) => !data.draft);

const byDateDesc = (a: (typeof all)[number], b: (typeof all)[number]) =>
  b.data.date.getTime() - a.data.date.getTime() || a.id.localeCompare(b.id);

// まず読むならこれ（編集部ピック。差し替えはこの3行を書き換えるだけ）
const pickDefs = [
  { id: '2026-07-13-ai-tools-1-same-question', role: 'まずはこの話から' },
  { id: '2026-07-09-clipboard-history', role: '今日から使える小ワザ' },
  { id: '2026-07-16-ai-shared-workspace', role: '一歩ふみこむ実践' },
];
const picks = pickDefs
  .map((p) => ({ ...p, entry: all.find((e) => e.id === p.id) }))
  .filter((p) => p.entry);

// 連載本編（ファイル名の連番順）と実践編（日付順）
const seriesItems = all.filter((e) => e.data.kind === 'series').sort((a, b) => a.id.localeCompare(b.id));
const practiceItems = all.filter((e) => e.data.kind === 'practice').sort((a, b) => byDateDesc(b, a));

// 単発Tips（kind未指定。新しい順）
const standalone = all.filter((e) => !e.data.kind).sort(byDateDesc);

const fmtDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<BaseLayout
  title="教えてAIさん"
  description="福祉の現場で役立つ、PC・AIの便利な使い方を「AIに聞いてみた」かたちでご紹介します。"
>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="教えてAIさん" href="/ai-tips/rss.xml" />
  </Fragment>
  <Hero
    eyebrow="教えてAIさん"
    title="AIに聞いてみた、<br />現場のちょっとした便利ワザ"
    lead="「パソコンやAIで、こんなことができるの？」——福祉の現場や暮らしで役立つコツを、AIに教わりながら少しずつ積み重ねていきます。"
    size="md"
    image="/images/ai-tips-hero.svg"
    imagePosition="center right"
    bright={true}
  />

  {picks.length > 0 && (
    <section class="section">
      <div class="container container--narrow">
        <h2 class="section__title">まず読むなら、これ</h2>
        <ul class="picks reveal">
          {picks.map((p) => (
            <li class="picks__item">
              <a href={`/ai-tips/${p.entry!.id}/`} class="picks__link">
                <span class="picks__role">{p.role}</span>
                <span class="picks__title">{p.entry!.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {seriesItems.length > 0 && (
    <section class="section section--sand">
      <div class="container container--narrow">
        <h2 class="section__title">連載でじっくり ―「AIに道具を持たせる」</h2>
        <p class="series-lead">
          同じ質問でも、道具の有無でAIの答えは変わります。AIに“手足”を持たせる考え方を、全5回で。少し歯ごたえのある中級者編です。
        </p>
        <div class="series-box reveal">
          <ol class="series-box__list">
            {seriesItems.map((item) => (
              <li class="series-box__item">
                <a href={`/ai-tips/${item.id}/`} class="series-box__link">
                  <span class="series-box__title">{item.data.title}</span>
                </a>
              </li>
            ))}
          </ol>
          {practiceItems.length > 0 && (
            <div class="series-box__practice">
              <p class="series-box__practice-label">あわせて読みたい、実践編</p>
              <ul class="series-box__practice-list">
                {practiceItems.map((item) => (
                  <li>
                    <a href={`/ai-tips/${item.id}/`} class="series-box__link">
                      <span class="series-box__badge">実践編</span>
                      <span class="series-box__title">{item.data.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section__title">単発の便利ワザ</h2>
      {standalone.length > 0 ? (
        <ul class="tips-list">
          {standalone.map((item, i) => (
            <li class="tips-list__item reveal" data-delay={(i % 3) + 1}>
              <a href={`/ai-tips/${item.id}/`} class="tips-list__link">
                <time class="tips-list__date" datetime={item.data.date.toISOString()}>
                  {fmtDate(item.data.date)}
                </time>
                <h3 class="tips-list__title">{item.data.title}</h3>
                {item.data.summary && (
                  <p class="tips-list__summary">{item.data.summary}</p>
                )}
                <span class="tips-list__arrow" aria-hidden="true">
                  <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
                    <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-soft text-center">記事は準備中です。もうしばらくお待ちください。</p>
      )}

      <AiTipsQuestionBox />

      <p class="text-soft text-center" style="margin-top:var(--space-7);">
        ※ このページは担当スタッフが随時更新します（Markdown ファイルを <code>src/content/ai-tips/</code> に追加するだけで反映）。
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* === まず読むなら、これ === */
  .picks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin-top: var(--space-5);
  }

  .picks__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    height: 100%;
    padding: var(--space-4);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    color: var(--color-ink);
    transition: background-color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }

  .picks__link:hover {
    background-color: rgba(74, 140, 63, 0.04);
    border-color: var(--color-green-700);
    color: var(--color-ink);
  }

  .picks__role {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-terra-500);
  }

  .picks__title {
    font-family: var(--font-hand);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-green-900);
    line-height: 1.6;
  }

  /* === 連載ボックス === */
  .series-lead {
    font-size: 14px;
    color: var(--color-ink-mute);
    margin-top: var(--space-3);
  }

  .series-box {
    margin-top: var(--space-5);
    border: 1px solid var(--color-line);
    border-radius: 14px;
    padding: var(--space-5);
    background-color: var(--color-paper, #fff);
  }

  .series-box__list {
    list-style: none;
    counter-reset: series;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .series-box__item {
    counter-increment: series;
    border-bottom: 1px dashed var(--color-line);
  }

  .series-box__item:last-child {
    border-bottom: none;
  }

  .series-box__item .series-box__link::before {
    content: counter(series);
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: var(--color-green-700);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .series-box__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-2);
    color: var(--color-ink);
    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .series-box__link:hover {
    background-color: rgba(74, 140, 63, 0.04);
    color: var(--color-ink);
  }

  .series-box__title {
    font-family: var(--font-hand);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-green-900);
    line-height: 1.6;
  }

  .series-box__practice {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-line);
  }

  .series-box__practice-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-ink-soft);
  }

  .series-box__practice-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
  }

  .series-box__badge {
    flex: none;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-terra-500);
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 1px 8px;
  }

  /* === 単発リスト（従来どおり） === */
  .tips-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    padding: 0;
    margin-top: var(--space-5);
  }

  .tips-list__item {
    border-top: 1px solid var(--color-line);
  }

  .tips-list__item:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .tips-list__link {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-4);
    color: var(--color-ink);
    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .tips-list__link:hover {
    background-color: rgba(74, 140, 63, 0.04);
    color: var(--color-ink);
  }

  .tips-list__date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
  }

  .tips-list__title {
    font-family: var(--font-hand);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-green-900);
    line-height: 1.6;
  }

  .tips-list__summary {
    grid-column: 2;
    font-size: 13px;
    color: var(--color-ink-mute);
    margin-top: var(--space-2);
  }

  .tips-list__arrow {
    color: var(--color-green-700);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .tips-list__link:hover .tips-list__arrow {
    transform: translateX(4px);
    color: var(--color-terra-500);
  }

  @media (max-width: 720px) {
    .picks {
      grid-template-columns: 1fr;
    }
    .series-box {
      padding: var(--space-4);
    }
    .tips-list__link {
      grid-template-columns: 1fr;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-3);
    }
    .tips-list__summary { grid-column: 1; }
    .tips-list__arrow { display: none; }
  }
</style>
