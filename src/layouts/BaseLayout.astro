---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCallBar from '../components/StickyCallBar.astro';
import { site } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  heroDark?: boolean;
  /** Override og image (relative to site root) */
  ogImage?: string;
}

const {
  title,
  description = site.description,
  ogImage = '/og-image.png',
} = Astro.props;

// ───────────────────────────────────────────────────────────────
// Cloudflare Web Analytics のビーコントークン。
// ダッシュボード（Analytics & Logs → Web Analytics → サイト追加）で
// 発行される data-cf-beacon の token をここに貼ると計測が始まります。
// 空のままなら何も出力されません（Cookieなし・個人を追跡しない計測）。
const CF_BEACON_TOKEN = '';
// ───────────────────────────────────────────────────────────────

const fullTitle = title === site.shortName ? site.name : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.legacyUrl).toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? site.legacyUrl).toString();

// 構造化データ（NGO = NPO法人。住所・連絡先は site.ts が唯一の情報源）
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: site.name,
  alternateName: site.shortName,
  url: site.legacyUrl,
  logo: new URL('/images/nest-image2/nest-logo-01.png', site.legacyUrl).toString(),
  image: ogImageUrl,
  description: site.description,
  foundingDate: '2006-08-15',
  telephone: site.tel,
  address: {
    '@type': 'PostalAddress',
    postalCode: '803-0851',
    addressRegion: '福岡県',
    addressLocality: '北九州市小倉北区',
    streetAddress: '木町3丁目6−7',
    addressCountry: 'JP',
  },
  sameAs: [site.instagram],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card（title/description/image は og:* にフォールバック） -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Theme color -->
    <meta name="theme-color" content="#faf6ef" media="(prefers-color-scheme: light)" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- 構造化データ（Organization / NGO） -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&family=Shippori+Mincho+B1:wght@500;600;700&family=Zen+Kurenaido&family=Zen+Maru+Gothic:wght@500;700&family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Mark JS available ASAP so .reveal animations engage only with JS -->
    <script is:inline>
      document.documentElement.classList.add('js-enabled');
    </script>

    <!-- ページ側から head に追記するためのスロット（noindex メタ等） -->
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">メインコンテンツへスキップ</a>

    <Header />

    <div class="site-shell">
      <main id="main">
        <slot />
      </main>

      <Footer />
    </div>

    <StickyCallBar />

    {
      CF_BEACON_TOKEN && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: CF_BEACON_TOKEN })}
        />
      )
    }

    <script>
      // Intersection Observer for fade-up reveals
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          // threshold 0: fire as soon as any part enters view. A larger
          // threshold can never be met by elements taller than ~10x the
          // viewport (e.g. long articles on mobile), leaving them stuck at
          // opacity:0 — a blank page. See long ai-tips articles on phones.
          { rootMargin: '0px 0px -80px 0px', threshold: 0 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
      }

      // Smooth scroll for in-page anchors
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const id = a.getAttribute('href')?.slice(1);
          if (!id) return;
          const target = document.getElementById(id);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
          }
        });
      });
    </script>
  </body>
</html>
