---
import { stats } from '../lib/site';
---

<section class="section section--sand" aria-label="数字で見るnest">
  <div class="container">
    <div class="stats-head reveal">
      <span class="eyebrow eyebrow--center">By the Numbers</span>
      <h2 class="section__title section__title--center">数字で見るnest</h2>
      <p class="section__lead section__lead--center">
        平成18年（2006年）の設立以来、地域とご家族とともに、ゆっくり、確かに育ててきた仕組みです。
      </p>
    </div>

    <div class="stats">
      {
        stats.map((s, i) => (
          <div class="stats__item reveal" data-delay={i + 1}>
            <div class="stats__value">
              <span class="stats__num" data-target={s.value}>0</span>
              <span class="stats__suffix">{s.suffix}</span>
            </div>
            <div class="stats__label">{s.label}</div>
            <div class="stats__sub">{s.sub}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats-head { text-align: center; margin-bottom: var(--space-7); }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  .stats__item {
    text-align: center;
    padding: var(--space-5) var(--space-4);
    position: relative;
  }

  .stats__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(-1 * var(--space-5) / 2);
    top: 20%;
    bottom: 20%;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--color-line) 30%, var(--color-line) 70%, transparent);
  }

  .stats__value {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    color: var(--color-green-900);
  }

  .stats__num {
    font-family: var(--font-serif);
    font-size: 64px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .stats__suffix {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--color-terra-500);
    font-weight: 500;
  }

  .stats__label {
    margin-top: var(--space-3);
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--color-ink);
    font-weight: 500;
  }

  .stats__sub {
    margin-top: var(--space-2);
    font-size: 12px;
    color: var(--color-ink-soft);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  @media (max-width: 880px) {
    .stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
    .stats__item:not(:last-child)::after { display: none; }
    .stats__item:nth-child(odd)::after {
      display: block;
      right: calc(-1 * var(--space-3) / 2);
      top: 25%;
      bottom: 25%;
    }
    .stats__num { font-size: 48px; }
  }
</style>

<script>
  // Animate counter on view
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const animateValue = (el: HTMLElement, target: number, duration = 1400) => {
    const start = performance.now();
    const step = (now: number) => {
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
      el.textContent = String(Math.floor(eased * target));
      if (t < 1) requestAnimationFrame(step);
      else el.textContent = String(target);
    };
    requestAnimationFrame(step);
  };

  const nums = document.querySelectorAll<HTMLElement>('.stats__num');

  if (reduceMotion) {
    nums.forEach((n) => {
      const t = Number(n.dataset.target ?? 0);
      n.textContent = String(t);
    });
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = Number(el.dataset.target ?? 0);
            animateValue(el, target);
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );
    nums.forEach((n) => io.observe(n));
  }
</script>
