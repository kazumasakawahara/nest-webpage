---
import { site } from '../lib/site';
---

<div class="sticky-cta" aria-label="モバイル用クイック連絡">
  <a href={`tel:${site.tel.replaceAll('-', '')}`} class="sticky-cta__btn sticky-cta__btn--call">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
    </svg>
    <span>お電話</span>
  </a>
  <a href="/contact/" class="sticky-cta__btn sticky-cta__btn--contact">
    <span>見学・お問い合わせ</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</div>

<style>
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(250, 246, 239, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--color-line);
    padding: 10px 12px calc(10px + env(safe-area-inset-bottom, 0px));
    z-index: 90;
    gap: 8px;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
  }

  .sticky-cta__btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 14px 12px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .sticky-cta__btn--call {
    background-color: var(--color-paper);
    color: var(--color-green-700);
    border: 1.5px solid var(--color-green-700);
  }

  .sticky-cta__btn--contact {
    background-color: var(--color-terra-500);
    color: #fff;
    border: 1.5px solid var(--color-terra-500);
  }

  .sticky-cta__btn:active {
    transform: scale(0.97);
  }

  @media (max-width: 768px) {
    .sticky-cta { display: flex; }
    /* Add bottom padding to body when CTA visible */
    :global(body) { padding-bottom: 80px; }
  }
</style>
