---
import { navLinks, site } from '../lib/site';

const currentPath = Astro.url.pathname;
// 公開静的ページでは locals.member は undefined。/members/* の SSR ページではセットされる。
const member = Astro.locals.member;
const membersLinkLabel = member ? '会員ページ' : '会員の方へ';

function isActive(href: string) {
  if (href === '/') return currentPath === '/' || currentPath === '/index.html';
  return currentPath.startsWith(href);
}
---

<!-- モバイル用トップバー（デスクトップでは非表示） -->
<div class="mobile-topbar">
  <a href="/" class="mobile-topbar__logo" aria-label="nest トップへ">
    <img
      src="/images/nest-image2/nest-logo-01.png"
      alt="特定非営利活動法人 nest"
      width="1633"
      height="687"
    />
  </a>
  <button
    class="mobile-topbar__burger"
    aria-label="メニューを開く"
    aria-expanded="false"
    aria-controls="site-nav"
    data-menu-trigger
  >
    <span></span><span></span><span></span>
  </button>
</div>

<header class="site-sidebar" id="site-nav" aria-label="サイドナビゲーション">
  <a href="/" class="sidebar__brand" aria-label="nest トップへ">
    <img
      class="sidebar__logo"
      src="/images/nest-image2/nest-logo-01-white.png"
      alt="特定非営利活動法人 nest"
      width="1633"
      height="687"
    />
  </a>

  <div class="sidebar__rule"></div>

  <nav class="sommaire" aria-label="メインナビゲーション">
    <ul class="sommaire__list">
      {
        navLinks.map((link, i) => (
          <li class:list={['sommaire__item', { 'has-sub': link.children }]}>
            <a
              href={link.href}
              class:list={['sommaire__link', { 'is-active': isActive(link.href) }]}
            >
              <span class="sommaire__num">{String(i + 1).padStart(2, '0')}</span>
              <span class="sommaire__lbl">{link.label}</span>
            </a>
            {link.children && (
              <ul class="sommaire__sub">
                {link.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={['sommaire__sublink', { 'is-active': isActive(child.href) }]}
                    >
                      — {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="sidebar__foot">
    <div class="sidebar__rule"></div>
    <p class="sidebar__ft-k">Contact</p>
    <a href={`tel:${site.tel.replaceAll('-', '')}`} class="sidebar__tel">
      {site.tel.replaceAll('-', ' ')}
    </a>
    <a
      href="/members/"
      class:list={['sidebar__member', { 'is-active': isActive('/members/') }]}
    >
      {membersLinkLabel}
    </a>
  </div>
</header>

<div class="sidebar__backdrop" data-menu-close aria-hidden="true"></div>

<style>
  /* ===== Sidebar (desktop, fixed left) ===== */
  .site-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: var(--sidebar-w);
    background-color: var(--color-green-900);
    color: var(--color-cream);
    display: flex;
    flex-direction: column;
    padding: 34px 24px 26px;
    overflow-y: auto;
    z-index: 100;
  }

  .sidebar__brand {
    display: block;
    text-decoration: none;
  }

  .sidebar__logo {
    display: block;
    width: 168px;
    max-width: 100%;
    height: auto;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .sidebar__brand:hover .sidebar__logo {
    opacity: 0.78;
  }

  .sidebar__rule {
    height: 1px;
    background-color: rgba(250, 246, 239, 0.16);
    margin: 22px 0 18px;
  }

  /* ===== Sommaire (numbered index nav) ===== */
  .sommaire {
    flex: 1;
  }

  .sommaire__list {
    list-style: none;
  }

  .sommaire__item {
    border-top: 1px solid rgba(250, 246, 239, 0.14);
  }

  .sommaire__item:first-child {
    border-top: none;
  }

  .sommaire__link {
    display: grid;
    grid-template-columns: 26px 1fr;
    align-items: baseline;
    gap: 4px;
    text-decoration: none;
    font-family: var(--font-serif);
    font-size: 15px;
    letter-spacing: 0.06em;
    padding: 9px 0;
    color: rgba(250, 246, 239, 0.82);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .sommaire__num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(250, 246, 239, 0.4);
    transform: translateY(-1px);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .sommaire__lbl {
    transition: transform var(--dur-base) var(--ease-out);
  }

  .sommaire__link:hover {
    color: #fff;
  }

  .sommaire__link:hover .sommaire__lbl {
    transform: translateX(3px);
  }

  .sommaire__link.is-active {
    color: #fff;
  }

  .sommaire__link.is-active .sommaire__num {
    color: var(--color-terra-500);
  }

  .sommaire__sub {
    list-style: none;
    padding: 0 0 8px 26px;
  }

  .sommaire__sublink {
    display: block;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    padding: 5px 0;
    color: rgba(250, 246, 239, 0.5);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .sommaire__sublink:hover,
  .sommaire__sublink.is-active {
    color: #fff;
  }

  /* ===== Foot (contact + members) ===== */
  .sidebar__foot {
    margin-top: auto;
    padding-top: 18px;
  }

  .sidebar__foot .sidebar__rule {
    margin: 0 0 16px;
  }

  .sidebar__ft-k {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(250, 246, 239, 0.5);
    margin-bottom: 7px;
  }

  .sidebar__tel {
    display: block;
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-cream);
    text-decoration: none;
  }

  .sidebar__tel:hover {
    color: var(--color-terra-500);
  }

  .sidebar__member {
    display: inline-block;
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(250, 246, 239, 0.7);
    padding-bottom: 3px;
    border-bottom: 1px solid rgba(250, 246, 239, 0.3);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .sidebar__member:hover {
    color: #fff;
  }

  .sidebar__member.is-active {
    color: #fff;
    border-color: var(--color-terra-500);
  }

  /* ===== Mobile top bar + drawer ===== */
  .mobile-topbar {
    display: none;
  }

  .sidebar__backdrop {
    display: none;
  }

  @media (max-width: 1024px) {
    .mobile-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 64px;
      padding: 0 12px 0 20px;
      background-color: rgba(250, 246, 239, 0.94);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--color-line-soft);
      z-index: 90;
    }

    .mobile-topbar__logo {
      display: flex;
      align-items: center;
      text-decoration: none;
    }

    .mobile-topbar__logo img {
      display: block;
      height: 34px;
      width: auto;
    }

    .mobile-topbar__burger {
      width: 44px;
      height: 44px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
    }

    .mobile-topbar__burger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background-color: var(--color-green-900);
      transition: transform var(--dur-base) var(--ease-out),
                  opacity var(--dur-base) var(--ease-out);
    }

    .mobile-topbar__burger[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(6.5px) rotate(45deg);
    }
    .mobile-topbar__burger[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
    }
    .mobile-topbar__burger[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-6.5px) rotate(-45deg);
    }

    /* Sidebar becomes an off-canvas drawer */
    .site-sidebar {
      width: min(320px, 86vw);
      padding-top: 80px;
      transform: translateX(-100%);
      transition: transform var(--dur-base) var(--ease-in-out);
      box-shadow: 10px 0 40px rgba(0, 0, 0, 0.18);
    }

    .site-sidebar.is-open {
      transform: none;
    }

    .sidebar__backdrop.is-open {
      display: block;
      position: fixed;
      inset: 0;
      background-color: rgba(26, 38, 32, 0.42);
      z-index: 80;
    }
  }
</style>

<script>
  const trigger = document.querySelector('[data-menu-trigger]') as HTMLButtonElement | null;
  const nav = document.querySelector('#site-nav') as HTMLElement | null;
  const backdrop = document.querySelector('.sidebar__backdrop') as HTMLElement | null;

  function closeMenu() {
    nav?.classList.remove('is-open');
    backdrop?.classList.remove('is-open');
    trigger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (trigger && nav) {
    trigger.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      backdrop?.classList.toggle('is-open', isOpen);
      trigger.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    backdrop?.addEventListener('click', closeMenu);

    // Close on link click (mobile drawer)
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        if (window.innerWidth <= 1024) closeMenu();
      });
    });
  }
</script>
