---
import { navLinks, site } from '../lib/site';

interface Props {
  /**
   * When the page has a hero with dark background, header starts transparent
   * and turns solid on scroll. When false, header is always solid.
   */
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/' || currentPath === '/index.html';
  return currentPath.startsWith(href);
}
---

<header class:list={['site-header', { 'is-transparent': transparent }]} data-transparent={transparent}>
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="nest トップへ">
      <span class="logo-mark">nest</span>
      <span class="logo-sub">NPO法人 ネスト</span>
    </a>

    <nav class="site-nav" aria-label="メインナビゲーション" id="site-nav">
      <ul class="site-nav__list">
        {
          navLinks.map((link) => (
            <li class:list={['site-nav__item', { 'has-dropdown': link.children }]}>
              <a
                href={link.href}
                class:list={['site-nav__link', { 'is-active': isActive(link.href) }]}
              >
                {link.label}
                {link.children && (
                  <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
                  </svg>
                )}
              </a>
              {link.children && (
                <ul class="site-nav__dropdown">
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={['site-nav__sublink', { 'is-active': isActive(child.href) }]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>

      <div class="site-nav__cta">
        <a href={`tel:${site.tel.replaceAll('-', '')}`} class="nav-call">
          <span aria-hidden="true">📞</span>
          <span>{site.tel}</span>
        </a>
      </div>
    </nav>

    <button
      class="site-header__menu-btn"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="site-nav"
      data-menu-trigger
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-cream);
    border-bottom: 1px solid transparent;
    transition: background-color var(--dur-base) var(--ease-out),
                border-color var(--dur-base) var(--ease-out),
                box-shadow var(--dur-base) var(--ease-out);
  }

  .site-header.is-transparent {
    background-color: transparent;
    border-bottom-color: transparent;
  }

  .site-header.is-transparent.is-scrolled,
  .site-header:not(.is-transparent) {
    background-color: rgba(250, 246, 239, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-line-soft);
    box-shadow: var(--shadow-soft);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    min-height: 72px;
  }

  .site-header__logo {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    color: var(--color-green-900);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .site-header.is-transparent:not(.is-scrolled) .site-header__logo {
    color: var(--color-cream);
  }

  .site-header__logo:hover { color: var(--color-terra-500); }

  .logo-mark {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .logo-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 4px;
    color: var(--color-ink-soft);
  }

  .site-header.is-transparent:not(.is-scrolled) .logo-sub {
    color: rgba(250, 246, 239, 0.75);
  }

  /* === Nav === */
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .site-nav__item {
    position: relative;
  }

  .site-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 10px 12px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
    position: relative;
  }

  .site-header.is-transparent:not(.is-scrolled) .site-nav__link {
    color: var(--color-cream);
  }

  .site-nav__link::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 4px;
    height: 1.5px;
    background-color: var(--color-terra-500);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--color-green-700);
  }

  .site-header.is-transparent:not(.is-scrolled) .site-nav__link:hover,
  .site-header.is-transparent:not(.is-scrolled) .site-nav__link.is-active {
    color: var(--color-cream);
  }

  .site-nav__link:hover::after,
  .site-nav__link.is-active::after {
    transform: scaleX(1);
  }

  /* Dropdown */
  .site-nav__dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 180px;
    background-color: var(--color-paper);
    border-radius: var(--radius-md);
    padding: var(--space-2) 0;
    box-shadow: var(--shadow-card);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity var(--dur-base) var(--ease-out),
                transform var(--dur-base) var(--ease-out),
                visibility var(--dur-base) var(--ease-out);
  }

  .site-nav__item.has-dropdown:hover .site-nav__dropdown,
  .site-nav__item.has-dropdown:focus-within .site-nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: none;
  }

  .site-nav__sublink {
    display: block;
    padding: 10px 18px;
    font-size: 14px;
    color: var(--color-ink);
  }

  .site-nav__sublink:hover,
  .site-nav__sublink.is-active {
    background-color: var(--color-green-100);
    color: var(--color-green-900);
  }

  /* Call CTA in nav */
  .nav-call {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--color-green-700);
    padding: 8px 14px;
    border: 1px solid var(--color-green-700);
    border-radius: var(--radius-pill);
    transition: all var(--dur-fast) var(--ease-out);
  }

  .nav-call:hover {
    background-color: var(--color-green-700);
    color: var(--color-cream);
  }

  .site-header.is-transparent:not(.is-scrolled) .nav-call {
    color: var(--color-cream);
    border-color: rgba(250, 246, 239, 0.5);
  }

  .site-header.is-transparent:not(.is-scrolled) .nav-call:hover {
    background-color: var(--color-cream);
    color: var(--color-green-900);
  }

  /* === Hamburger === */
  .site-header__menu-btn {
    display: none;
    width: 44px;
    height: 44px;
    padding: 12px 10px;
    position: relative;
  }

  .site-header__menu-btn span {
    display: block;
    height: 1.5px;
    width: 22px;
    background-color: var(--color-green-900);
    margin: 5px auto;
    transition: all var(--dur-base) var(--ease-out);
  }

  .site-header.is-transparent:not(.is-scrolled) .site-header__menu-btn span {
    background-color: var(--color-cream);
  }

  .site-header__menu-btn[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-header__menu-btn[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .site-header__menu-btn[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* === Mobile === */
  @media (max-width: 1024px) {
    .site-header__menu-btn { display: block; }

    .site-nav {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(360px, 88vw);
      background-color: var(--color-cream);
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      padding: 88px var(--space-5) var(--space-7);
      gap: var(--space-5);
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform var(--dur-base) var(--ease-in-out);
      box-shadow: -10px 0 40px rgba(0, 0, 0, 0.1);
    }

    .site-nav.is-open {
      transform: none;
    }

    .site-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      width: 100%;
    }

    .site-nav__item {
      border-bottom: 1px solid var(--color-line-soft);
    }

    .site-nav__link {
      width: 100%;
      padding: 16px 8px;
      font-size: 16px;
      font-family: var(--font-serif);
      justify-content: space-between;
      color: var(--color-ink) !important;
    }

    .site-nav__dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      background-color: var(--color-green-100);
      padding: 8px 16px;
      border-radius: var(--radius-md);
      margin-bottom: 12px;
    }

    .site-nav__cta {
      margin-top: auto;
    }

    .nav-call {
      width: 100%;
      justify-content: center;
      padding: 14px;
      font-size: 16px;
      color: var(--color-green-700) !important;
      border-color: var(--color-green-700) !important;
    }

    /* Backdrop */
    .site-nav.is-open::before {
      content: '';
      position: fixed;
      inset: 0;
      background-color: rgba(26, 38, 32, 0.4);
      z-index: -1;
    }
  }
</style>

<script>
  // Sticky header background toggle
  const header = document.querySelector('.site-header');
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 24) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Mobile menu toggle
  const trigger = document.querySelector('[data-menu-trigger]') as HTMLButtonElement | null;
  const nav = document.querySelector('#site-nav') as HTMLElement | null;
  if (trigger && nav) {
    trigger.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    // Close on link click (mobile)
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        if (window.innerWidth <= 1024) {
          nav.classList.remove('is-open');
          trigger.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }
      });
    });
  }
</script>
