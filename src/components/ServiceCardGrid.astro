---
interface Card {
  title: string;
  body: string;
  href: string;
  badge?: string;
  icon?: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  cards: Card[];
  columns?: 2 | 3;
}

const { cards, columns = 3 } = Astro.props;
---

<div class:list={['svc-grid', `svc-grid--${columns}`]}>
  {
    cards.map((c, i) => (
      <a href={c.href} class="svc-card reveal" data-delay={(i % 3) + 1}>
        <div class="svc-card__media">
          {c.image ? (
            <img src={c.image} alt={c.imageAlt ?? ''} loading="lazy" />
          ) : (
            <div class="ph ph--landscape">
              <span class="ph__label">{c.title.slice(0, 12)}</span>
            </div>
          )}
          {c.badge && <span class="svc-card__badge badge badge--active">{c.badge}</span>}
        </div>
        <div class="svc-card__body">
          {c.icon && <div class="svc-card__icon" aria-hidden="true">{c.icon}</div>}
          <h3 class="svc-card__title">{c.title}</h3>
          <p class="svc-card__text">{c.body}</p>
          <span class="svc-card__arrow" aria-hidden="true">
            <svg width="16" height="12" viewBox="0 0 16 12" fill="none">
              <path d="M1 6h14M10 1l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </div>
      </a>
    ))
  }
</div>

<style>
  .svc-grid {
    display: grid;
    gap: var(--space-5);
  }

  .svc-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .svc-grid--3 { grid-template-columns: repeat(3, 1fr); }

  .svc-card {
    background-color: var(--color-paper);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-line);
    color: var(--color-ink);
    transition: transform var(--dur-base) var(--ease-out),
                box-shadow var(--dur-base) var(--ease-out);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .svc-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    color: var(--color-ink);
  }

  .svc-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    position: relative;
  }

  .svc-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .svc-card:hover .svc-card__media img {
    transform: scale(1.05);
  }

  .svc-card__media .ph {
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  .svc-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
  }

  .svc-card__body {
    padding: var(--space-5) var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .svc-card__icon {
    font-size: 24px;
    line-height: 1;
  }

  .svc-card__title {
    font-family: var(--font-hand);
    font-size: 19px;
    font-weight: 600;
    color: var(--color-green-900);
    line-height: 1.5;
  }

  .svc-card__text {
    font-size: 14px;
    color: var(--color-ink-mute);
    line-height: var(--lh-normal);
    flex-grow: 1;
  }

  .svc-card__arrow {
    align-self: flex-end;
    color: var(--color-green-700);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-green-100);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all var(--dur-fast) var(--ease-out);
  }

  .svc-card:hover .svc-card__arrow {
    background: var(--color-terra-500);
    color: #fff;
    transform: translateX(4px);
  }

  @media (max-width: 880px) {
    .svc-grid--2,
    .svc-grid--3 { grid-template-columns: 1fr; }
  }
</style>
