---
interface Props {
  eyebrow?: string;
  title: string;
  /** Optional 2nd line in display */
  titleSub?: string;
  lead?: string;
  /** Hero size variant */
  size?: 'lg' | 'md' | 'sm';
  /** Background image URL (place in /public) */
  image?: string;
  /** Image position 'center' | 'top' etc */
  imagePosition?: string;
  /** Placeholder label when no image */
  placeholderLabel?: string;
}

const {
  eyebrow,
  title,
  titleSub,
  lead,
  size = 'lg',
  image,
  imagePosition = 'center',
  placeholderLabel = 'HERO IMAGE',
} = Astro.props;
---

<section class:list={['hero', `hero--${size}`]} aria-label="ヒーロー">
  {
    image ? (
      <div class="hero__bg" style={`background-image:url(${image}); background-position:${imagePosition};`} aria-hidden="true" />
    ) : (
      <div class="hero__bg hero__bg--ph" aria-hidden="true">
        <span class="hero__ph-label">{placeholderLabel}</span>
      </div>
    )
  }
  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__inner">
    <div class="hero__content reveal">
      {eyebrow && <span class="eyebrow eyebrow--light">{eyebrow}</span>}
      <h1 class="hero__title">
        <Fragment set:html={title} />
        {titleSub && <><br /><span class="hero__title-sub" set:html={titleSub} /></>}
      </h1>
      {lead && <p class="hero__lead">{lead}</p>}
      <slot />
    </div>
  </div>

  {
    size === 'lg' && (
      <div class="hero__scroll" aria-hidden="true">
        <span>SCROLL</span>
        <span class="hero__scroll-line"></span>
      </div>
    )
  }
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    color: var(--color-cream);
    overflow: hidden;
    isolation: isolate;
  }

  .hero--lg { min-height: 78vh; min-height: 78dvh; padding: 120px 0 100px; }
  .hero--md { min-height: 56vh; min-height: 56dvh; padding: 96px 0 80px; }
  .hero--sm { min-height: 38vh; min-height: 38dvh; padding: 80px 0 60px; }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-color: var(--color-green-900);
    background-size: cover;
    background-position: center;
    z-index: -2;
    transition: transform 1.2s var(--ease-out);
  }

  .hero__bg--ph {
    background:
      radial-gradient(ellipse at 30% 40%, rgba(217, 119, 87, 0.35), transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(74, 140, 63, 0.4), transparent 55%),
      linear-gradient(135deg, var(--color-green-900), var(--color-green-700) 50%, var(--color-terra-700));
  }

  .hero__ph-label {
    position: absolute;
    top: 96px;
    right: 24px;
    color: rgba(250, 246, 239, 0.5);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px dashed rgba(250, 246, 239, 0.35);
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
  }

  /* 文字が乗る左側だけを暗く沈め、右の写真は明るいまま残す（可読性を担保しつつ写真を活かす） */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(100deg,
        rgba(16, 34, 17, 0.88) 0%,
        rgba(16, 34, 17, 0.72) 30%,
        rgba(16, 34, 17, 0.45) 52%,
        rgba(16, 34, 17, 0.18) 70%,
        rgba(16, 34, 17, 0) 88%);
  }

  .hero__overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(16, 34, 17, 0.5), rgba(16, 34, 17, 0) 42%);
  }

  .hero__inner {
    position: relative;
    width: 100%;
    padding-left: clamp(24px, 7%, 112px);
    padding-right: var(--space-5);
  }

  .hero__content {
    max-width: 600px;
  }

  .eyebrow--light {
    color: var(--color-terra-100);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: var(--fs-display);
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-cream);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-4);
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.5), 0 1px 2px rgba(0, 0, 0, 0.35);
    /* 日本語を文節単位で改行（「場／所」のような語中分断を防ぐ）。
       禁則処理も有効化。未対応ブラウザは normal にフォールバック。 */
    line-break: strict;
    word-break: auto-phrase;
  }

  .hero__title-sub {
    font-size: 0.78em;
    color: rgba(250, 246, 239, 0.9);
  }

  .hero__lead {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.9;
    color: rgba(250, 246, 239, 0.95);
    max-width: 600px;
    margin-bottom: var(--space-5);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.45);
    line-break: strict;
    word-break: auto-phrase;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 32px;
    right: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    color: rgba(250, 246, 239, 0.6);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    z-index: 2;
  }

  .hero__scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(180deg, rgba(250, 246, 239, 0.6), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-terra-500), transparent);
    transform: translateY(-100%);
    animation: scrollDown 2.2s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  @media (max-width: 768px) {
    .hero--lg { min-height: 64vh; min-height: 64dvh; padding: 100px 0 80px; }
    .hero--md { min-height: 48vh; min-height: 48dvh; padding: 80px 0 64px; }
    .hero__scroll { display: none; }

    /* モバイルは文字が全幅に広がるため、左方向ではなく縦方向の均一なスクリムで可読性を担保 */
    .hero__overlay {
      background: linear-gradient(
        180deg,
        rgba(16, 34, 17, 0.5) 0%,
        rgba(16, 34, 17, 0.34) 38%,
        rgba(16, 34, 17, 0.58) 100%
      );
    }
    .hero__overlay::after { background: none; }

    .hero__inner { padding-left: var(--space-5); }
  }
</style>
