---
interface Props {
  title: string;
  note?: string;
  icon?: string;
  minHeight?: string;
}

const { title, note, icon = '🔗', minHeight = '420px' } = Astro.props;
---

<div class="iframe-ph" style={`min-height:${minHeight};`}>
  <div class="iframe-ph__icon" aria-hidden="true">{icon}</div>
  <div class="iframe-ph__title">{title}</div>
  {note && <p class="iframe-ph__note">{note}</p>}
</div>

<style>
  .iframe-ph__icon {
    font-size: 32px;
    margin-bottom: var(--space-3);
    opacity: 0.6;
  }
</style>
