---
import { site, navLinks } from '../lib/site';
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">

      <div class="site-footer__brand">
        <img
          src="/images/nest-image2/nest-logo-01-white.png"
          alt="特定非営利活動法人 nest"
          class="footer-logo"
          width="1633"
          height="687"
          loading="lazy"
        />
        <p class="footer-tagline">巣立っても、いつでも帰ってこられる</p>
      </div>

      <div class="site-footer__col">
        <h4 class="site-footer__heading">サイトマップ</h4>
        <ul class="site-footer__list">
          {navLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <div class="site-footer__col">
        <h4 class="site-footer__heading">事業所</h4>
        <ul class="site-footer__list">
          <li><a href="/kimachiya/">キッチン＆マルシェ 木町家</a></li>
          <li><a href="/nest-design/">nest Design</a></li>
          <li><a href="/group-home/">グループホーム</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h4 class="site-footer__heading">事務局</h4>
        <address class="site-footer__address">
          <p>{site.name}</p>
          <p>{site.address}</p>
          <p>
            TEL/FAX <a href={`tel:${site.tel.replaceAll('-', '')}`}>{site.tel}</a><br>
            <span class="text-soft">電話受付 {site.telHours}</span>
          </p>
        </address>
      </div>

    </div>

    <div class="site-footer__base">
      <p class="site-footer__copy">{site.copyright}</p>
      <ul class="site-footer__meta">
        <li><a href="/privacy/">プライバシーポリシー</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-green-900);
    color: var(--color-cream);
    padding: var(--space-9) 0 var(--space-5);
    margin-top: var(--space-9);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1.4fr;
    gap: var(--space-7);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid rgba(250, 246, 239, 0.15);
  }

  .footer-logo {
    display: block;
    width: 168px;
    height: auto;
    margin-bottom: var(--space-4);
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-size: 15px;
    color: rgba(250, 246, 239, 0.78);
    margin-bottom: var(--space-5);
    line-height: 1.7;
  }

  .site-footer__heading {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-terra-500);
    margin-bottom: var(--space-4);
  }

  .site-footer__list { display: flex; flex-direction: column; gap: var(--space-3); }
  .site-footer__list a {
    font-size: 14px;
    color: rgba(250, 246, 239, 0.85);
  }
  .site-footer__list a:hover { color: var(--color-terra-500); }

  .site-footer__address {
    font-style: normal;
    font-size: 14px;
    line-height: 1.85;
    color: rgba(250, 246, 239, 0.85);
  }

  .site-footer__address p { margin-bottom: var(--space-3); }
  .site-footer__address a {
    color: var(--color-cream);
    font-weight: 600;
    border-bottom: 1px dotted rgba(250, 246, 239, 0.5);
  }
  .site-footer__address a:hover { color: var(--color-terra-500); }

  .site-footer__base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-5);
    flex-wrap: wrap;
  }

  .site-footer__copy {
    font-size: 12px;
    color: rgba(250, 246, 239, 0.5);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  .site-footer__meta {
    display: flex;
    gap: var(--space-5);
  }

  .site-footer__meta a {
    font-size: 12px;
    color: rgba(250, 246, 239, 0.7);
  }

  .site-footer__meta a:hover { color: var(--color-terra-500); }

  @media (max-width: 880px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }

    .site-footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 540px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
