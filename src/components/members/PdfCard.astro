---
interface Props {
  title: string;
  subtitle?: string;
  downloadHref: string;
  viewHref?: string | null;
  thumbnailUrl?: string | null;
}
const { title, subtitle, downloadHref, viewHref, thumbnailUrl } = Astro.props;
---

<article class="pdfc">
  <div class="pdfc__thumb">
    {viewHref && thumbnailUrl ? (
      <a href={viewHref} target="_blank" rel="noopener" aria-label={`${title} を閲覧`}>
        <img src={thumbnailUrl} alt="" loading="lazy" />
      </a>
    ) : thumbnailUrl ? (
      <img src={thumbnailUrl} alt="" loading="lazy" />
    ) : (
      <span class="pdfc__ph">PDF 表紙</span>
    )}
  </div>
  <div class="pdfc__body">
    <h3 class="pdfc__title">{title}</h3>
    {subtitle && <p class="pdfc__sub">{subtitle}</p>}
    <div class="pdfc__actions">
      {viewHref && (
        <a href={viewHref} target="_blank" rel="noopener" class="btn btn--outline btn--sm">閲覧</a>
      )}
      <a href={downloadHref} class="btn btn--primary btn--sm">ダウンロード</a>
    </div>
  </div>
</article>

<style>
  .pdfc {
    display: flex;
    flex-direction: column;
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }
  .pdfc__thumb {
    aspect-ratio: 3 / 4;
    background: var(--color-sand);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pdfc__thumb a { display: block; width: 100%; height: 100%; }
  .pdfc__thumb img { width: 100%; height: 100%; object-fit: contain; }
  .pdfc__ph { color: var(--color-ink-mute); font-size: var(--fs-small); }
  .pdfc__body { padding: var(--space-4); display: grid; gap: var(--space-2); }
  .pdfc__title { font-family: var(--font-heading); margin: 0; }
  .pdfc__sub { color: var(--color-ink-mute); margin: 0; }
  .pdfc__actions { display: flex; gap: var(--space-2); margin-top: var(--space-1); }
</style>
