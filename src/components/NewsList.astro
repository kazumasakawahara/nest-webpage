---
import { getCollection, render } from 'astro:content';

interface Props {
  limit?: number;
  showSummary?: boolean;
}

const { limit, showSummary = false } = Astro.props;

const all = await getCollection('news', ({ data }) => !data.draft);
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const items = limit ? sorted.slice(0, limit) : sorted;

const fmtDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<ul class="news-list">
  {
    items.map((item, i) => (
      <li class="news-list__item reveal" data-delay={(i % 3) + 1}>
        <a href={`/news/${item.id}/`} class="news-list__link">
          <time class="news-list__date" datetime={item.data.date.toISOString()}>
            {fmtDate(item.data.date)}
          </time>
          <span class="news-list__tag badge badge--accent">{item.data.tag}</span>
          <h3 class="news-list__title">{item.data.title}</h3>
          {showSummary && item.data.summary && (
            <p class="news-list__summary">{item.data.summary}</p>
          )}
          <span class="news-list__arrow" aria-hidden="true">
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
              <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .news-list__item {
    border-top: 1px solid var(--color-line);
  }

  .news-list__item:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .news-list__link {
    display: grid;
    grid-template-columns: 120px auto 1fr auto;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-4);
    color: var(--color-ink);
    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .news-list__link:hover {
    background-color: rgba(74, 140, 63, 0.04);
    color: var(--color-ink);
  }

  .news-list__date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
  }

  .news-list__title {
    font-family: var(--font-hand);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-green-900);
    line-height: 1.6;
  }

  .news-list__summary {
    grid-column: 3;
    font-size: 13px;
    color: var(--color-ink-mute);
    margin-top: var(--space-2);
  }

  .news-list__arrow {
    color: var(--color-green-700);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .news-list__link:hover .news-list__arrow {
    transform: translateX(4px);
    color: var(--color-terra-500);
  }

  @media (max-width: 720px) {
    .news-list__link {
      grid-template-columns: 1fr;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-3);
    }

    .news-list__arrow {
      display: none;
    }
  }
</style>
